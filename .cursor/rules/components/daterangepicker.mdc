    const dateFormat = 'MM/DD/YYYY';
    const startingDateEmpty = isEmpty(
      startingDateRef.current.textFieldInputRef.value
    );
    const endingDateEmpty = isEmpty(
      endingDateRef.current.textFieldInputRef.value
    );

    const dateFormats = [dateFormat, 'YYYY.MM.DD', 'YY.MM.DDDD', 'YYMMDD'];
    const sanitizedStartingDateWrapper = moment(
      startingDateRef.current.textFieldInputRef.value,
      dateFormats,
      true
    );
    const sanitizedEndingDateWrapper = moment(
      endingDateRef.current.textFieldInputRef.value,
      dateFormats,
      locale
    );

    if (
      !startingDateEmpty &&
      (!sanitizedStartingDateWrapper || !sanitizedStartingDateWrapper.isValid())
    ) {
      errorTextUpdate = startingDateErrorText;
    }

    if (
      !endingDateEmpty &&
      (!sanitizedEndingDateWrapper || !sanitizedEndingDateWrapper.isValid())
    ) {
      errorTextUpdate = endingDateErrorText;
    }

    const startingDateWrapper = moment(startDateValue, dateFormat, true);
    const endingDateWrapper = moment(endDateValue, dateFormat, true);
    if (!startingDateEmpty && !endingDateEmpty) {
