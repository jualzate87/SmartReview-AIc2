## Usage Patterns

### Showcase

```tsx
() => {
  const [startingDate, setStartingDate] = React.useState('02/25/2025');
  const [endingDate, setEndingDate] = React.useState('03/25/2025');

  const handleStartingDateChange = (event: ChangeEventType) => {
    const { value: newValue } = event.target as HTMLInputElement;
    setStartingDate(newValue);
  };

  const handleEndingDateChange = (event: ChangeEventType) => {
    const { value: newValue } = event.target as HTMLInputElement;
    setEndingDate(newValue);
  };

  return (
    <div>
      <DateRangePicker
        locale="ar_aa"
        startDateLabel="Start Date"
        startingDate={startingDate}
        endDateLabel="End Date"
        endingDate={endingDate}
        dateFormat="MMM dd YYYY"
        placeholder="MMM YYYY (placeholder)"
        minDate="02/25/2025"
        maxDate="06/25/2025"
        maxDuration={5}
        blackoutDates={['2025-03-21', '2025-03-22', '2025-04-21']}
        automationId="DateRangePicker__playground"
        size="medium"
        onStartingDateChange={handleStartingDateChange}
        onEndingDateChange={handleEndingDateChange}
        onStartingDateInputChange={action(
          'DateRangePicker onStartingDateInputChange fired, with data:'
        )}
        onEndingDateInputChange={action(
          'DateRangePicker onEndingDateInputChange fired, with data:'
        )}
      />
    </div>
  );
}
```

