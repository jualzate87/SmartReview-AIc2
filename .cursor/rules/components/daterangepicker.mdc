        errorTextUpdate = startEndDateErrorText;
      }

      const maxDuration = 7;
      const maxEndDate = startingDateWrapper.add(maxDuration, 'days');
      if (endingDateWrapper.isAfter(maxEndDate)) {
        errorTextUpdate = 'The ending date cannot be beyond max duration';
      }
    }

    setErrorText(errorTextUpdate);
  }, [startDateValue, endDateValue]);

  const startRef = (c?: any) => {
    startingDateRef.current = c;
  };

  const endRef = (c?: any) => {
    endingDateRef.current = c;
  };

  const handleStartingDateChange = (event: ChangeEventType) => {
    const targetElement = event.target as HTMLInputElement;
    setStartDateValue(targetElement.value);
  };
// ...
```

