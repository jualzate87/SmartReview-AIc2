<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface DateRangePickerProps
  extends Omit<ThemeableElement<'div'>, 'onChange'> {
  /**
   * Placeholder for the date range picker.
   */
  placeholder?: string;
  /**
   * Automation ID prop for allowing easier access to elements while running functional tests.
   * USAGE: User would just need to provide the automationId prop during instantiation, and
   * behind the scene we would add it to dateRangePicker
   */
  automationId?: string;
  /**
   * Sets the date format used by moment to display dates and parse entered dates. Please note
   * that this string is automatically upperCased before being passed to moment to preserve
   * backwards compatibility with the previous React-shimmed DatePicker.
   * Moment doesn't seem to have a built-in way to check if this is valid, so if the user passes
   * in a bad dateFormat, things will break.
   *
   * @default 'MM/DD/YYYY'
   */
  dateFormat: string;
  /** Id of the datePicker container */
  id?: string;
  /**
   * A date in short ISO format indicating the latest date, inclusive, for which this component is valid.
   * On a desktop, setting this value will prevent the date-picker's calendar from navigating to any dates after it.
   * This is used as a prop by both datePropParser and the component that gets generated from it.
   * DatePropParser should only take a string, and its child component should only take a DateWrapper object.
   * The string "maxDate" is hard-coded in datePropUtils.
   */
  maxDate?: string | DateWrapper;
  /**
   *  A date in short ISO format indicating the earliest date, inclusive, for which this component
   *  is valid. On a desktop, setting this value will prevent the DatePicker's calendar from
   *  navigating to any dates prior to it.
   * This is used as a prop by both datePropParser and the component that gets generated from it.
   * DatePropParser should only take a string, and its child component should only take a DateWrapper object.
   * The string "minDate" is hard-coded in datePropUtils.
   */
  minDate?: string | DateWrapper;
  /**
   * Fires when the input changes for the starting date component. Fires on keystrokes and on selection.
   */
  onStartingDateInputChange?: (event: ChangeEventType) => void;
  /**
   * Fires when the input changes for the ending date component. Fires on keystrokes and on selection.
   */
  onEndingDateInputChange?: (event: ChangeEventType) => void;
  /**
   * Fires when a change event comes from the starting date HADatePicker.
   * See HADatePicker documentation for information about this change event.
   */
  onStartingDateChange?: (event: ChangeEventType) => void;
  /**
   * Fires when a change event comes from the ending date HADatePicker.
   * See HADatePicker documentation for information about this change event.
   */
  onEndingDateChange?: (event: ChangeEventType) => void;
  /** Fires when either DatePicker changes. See DatePicker.props.onChange. */
  onChange?: React.ChangeEventHandler;
  /**
   *  The current locale in the user's browser. If not supplied, DatePropParser defaults this to
   *  navigator.userLanguage || navigator.language || 'en' . Since that is not an optimal way to
   *  get the locale, it's recommended that plugins override this setting. This setting controls
   *  the date format, the day of the week headings and the names of each month, which are all
   *  supplied by [moment](https://momentjs.com/). However, the user can override all of these
   *  options individually if desired. Please note that in addition to locale, you must still
   *  supply all proper error messages and a placeholder (if desired) in the right language in
   *  order for this widget to be used in non-English speaking regions. (See HUI-5049)
   *
   * @default 'en'
   */
  locale: string;
  /**
   * The selected date in the starting date HADatePicker. DateRangePicker consumers should
   * supply a valid date in short ISO format.
   */
  startingDate?: string | DateWrapper;
  /**
   * The selected date in the ending date HADatePicker. DateRangePicker consumers should
   * supply a valid date in short ISO format.
   */
  endingDate?: string | DateWrapper;
  /** Label for the Start Date field. */
  startDateLabel?: string;
  /** flag to enable month selector. */
  isMonthYearPicker?: boolean;
  /** Label for the End Date field. */
  endDateLabel?: string;
  /** aria-label for the Start Date field in case label is not defined */
  startDateAriaLabel?: string;
  /**  aria-label for the End Date field in case label is not defined. */
  endDateAriaLabel?: string;
  /** Error text for starting datePicker */
  errorTextStartDate?: string;
  /** Error text for ending datePicker */
  errorTextEndDate?: string;
  /**
   * Disables both date pickers
   *
   * @default false
   */
  disabled?: boolean;
  /**
   * The maximum number of days between the start date and the end date.
   * For example, if set to "2", the end date must be either one or two days after the start date.
   *
   * @default Infinity
   */
  maxDuration?: number;
  /** Size of the form fields to support */
  size?: DatePickerProps['size'];
  /** Pass this in to get a ref to the starting date DatePicker. */
  startDateRef?: (c?: any) => void;
  /** Pass this in to get a ref to the ending date DatePicker. */
  endDateRef?: (c?: any) => void;
}
```

