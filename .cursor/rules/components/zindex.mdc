## Code Example

```tsx
import IDSContext from '@ids/context';
import ZIndex from '@ids-ts/zindex';

class Tooltip extends React.Component {
    ...
    render() {
        ...

        return (
            ...
            <IDSContext.Consumer>
                {
                    (context) => (
                        <ZIndex
                            assignZIndex={openProp}
                            getCurrentBaseZIndex={context.getCurrentBaseZIndex}
                            incrementBaseZIndex={context.incrementBaseZIndex}
                            decrementBaseZIndex={context.decrementBaseZIndex}
                        >
                            <Position
                                offsetSkidding={offsetSkidding}
                                offsetDistance={offsetDistance}
                                targetElement={this.target}
                                position={position}
                                style={{ pointerEvents: 'none' }}
                                alignment={alignment}
                                show={openProp}
                            >
                                <Transition
                                    transition={openProp ? transitions.enter : transitions.exit}
                                    unmountOnExit
                                >
                                    {content}
                                </Transition>
                            </Position>
                        </ZIndex>
                    )
                }
            </IDSContext.Consumer>
            ...
        );
    }
}

...
```

