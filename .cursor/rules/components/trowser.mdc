  /** callback for when icon clicked */
  onHelpIconClick?: MouseOrKeyboardEventFunction;
  /** callback for when icon clicked */
  onHistoryIconClick?: MouseOrKeyboardEventFunction;
  /** callback for when a key is pressed */
  onKeyDown?: KeyboardDIVEventFunction;
  /** callback for when search icon clicked */
  onSearchIconClick?: MouseOrKeyboardEventFunction;
  /** callback for when icon clicked */
  onSettingsIconClick?: MouseOrKeyboardEventFunction;
  /** callback for when trowser is shown */
  onShow?: EnterHandler<undefined>;
  /** class name for body content of trowser */
  sectionClassName?: string;
  /** shows search button */
  search?: boolean;
  /** label to change search label in overflow menu and aria text */
  searchLabel?: string;
  /** shows settings button */
  settings?: boolean;
  /** label to change settings label in overflow menu and aria text */
  settingsLabel?: string;
  /** whether to show the cancel link in the footer */
