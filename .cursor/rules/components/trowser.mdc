### Trowser With Refocus

```tsx
() => {
  const [loading, setLoading] = React.useState(true);

  const completeLoading = () => {
    setTimeout(() => {
      setLoading(false);
    }, 2000);
  };

  return (
    <div>
      <TrowserMixin>
        {(props: TrowserMixinProps) => (
          <div>
            <Button
              purpose="standard"
              onClick={() => {
                props.onShowTrowser();
                completeLoading();
              }}
            >
              Basic Trowser
            </Button>
            <Trowser
              dismissible
              open={props.open}
              title="Basic Trowser with Refocus"
              refocus={!loading}
              footerButton={[
                <Button key="btn-primary-1" onClick={props.onFooterButtonClick}>
                  Primary
                </Button>,
                <Button
                  key="btn-primary-2"
                  priority="secondary"
                  onClick={props.onFooterButtonClick}
                >
                  Secondary
                </Button>
              ]}
              onShow={action('Trowser is showing')}
              onClose={props.onCloseTrowser}
            >
              <section>
                <div>
                  <div
                    style={{
                      display: 'flex',
                      alignItems: 'center',
                      justifyContent: 'center'
                    }}
                  >
                    {loading ? (
                      <IndeterminateShort
                        data-testid="loading-spinner"
                        size={16}
                      />
                    ) : (
                      <Dropdown
                        label="Coffee"
                        onChange={props.handlePageLevelDropdownChange}
                      >
                        <MenuItem value="LATTE">Latte</MenuItem>
                        <MenuItem value="ESPRESSO">Espresso</MenuItem>
                        <MenuItem value="Decafe">Decafe</MenuItem>
                      </Dropdown>
                    )}
                  </div>
                </div>
              </section>
            </Trowser>
          </div>
        )}
      </TrowserMixin>
    </div>
  );
}
