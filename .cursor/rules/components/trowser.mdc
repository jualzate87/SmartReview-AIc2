() => {
  const [open, setOpen] = useState(false);

  return (
    <div>
      <Button purpose="standard" onClick={() => setOpen(true)}>
        Open Trowser with Header Content
      </Button>
      <Trowser
        dismissible
        feedback
        help
        automationId="trowser-header-content"
        headerRightContent={
          <Button
            priority="primary"
            purpose="ai"
            size="small"
            onClick={action('Custom button clicked')}
          >
            <AiSparkles size="xsmall" />
            Show me how
          </Button>
        }
        open={open}
        title="Trowser with Custom Header Content"
        onClose={() => setOpen(false)}
        onFeedbackIconClick={action('Feedback clicked')}
        onHelpIconClick={action('Help clicked')}
      >
        <div style={{ padding: '24px' }}>
          <h3>Custom Header Content Example</h3>
          <p>
            This Trowser demonstrates the <code>headerRightContent</code> prop,
            which allows you to inject custom React content into the header
            right section before the standard icons.
          </p>
        </div>
      </Trowser>
    </div>
  );
}
