## Usage Patterns

### Basic Usage Default Theme

```tsx
() => {
  const footerCenterLinkLabels = [
    'Action 1',
    'Action 2',
    'Action 3',
    'Action 4'
  ];

  const buttonRef = useRef(null);

  return (
    <div>
      <TrowserMixin>
        {(props: TrowserMixinProps) => {
          return (
            <div>
              <Button purpose="standard" onClick={props.onShowTrowser}>
                Basic Trowser
              </Button>
              <Trowser
                feedback
                help
                history
                search
                settings
                dismissible
                showCancelFooterButton
                automationId="Default_Theme"
                open={props.open}
                title="Basic Trowser"
                renderFlyout={(buttonEl: React.ReactElement) => {
                  return (
                    <>
                      {buttonEl}
                      <Popover
                        disableAutoFocus
                        className={styles.trowserPopoverWithMenuItem}
                        popoverOffsetDistance={16}
                        open={props.isMoreMenuOpen}
                        targetElement={buttonRef.current}
                        position="top"
                        onClose={props.onMenuClose}
                      >
                        <PopoverContent alignment="center">
                          {footerCenterLinkLabels.slice(2).map((label) => (
                            <MenuItem
                              key={label}
                              onClick={props.onMenuSelect}
                              onKeyDown={props.onMenuKeyDown}
                            >
                              {label}
                            </MenuItem>
                          ))}
                        </PopoverContent>
                      </Popover>
                    </>
                  );
                }}
                moreButton={
                  <Button
                    innerRef={buttonRef}
                    priority="tertiary"
                    onClick={() => {
                      props.toggleMoreMenu();
                    }}
                  >
                    More
                  </Button>
                }
                footerButton={[
                  <Button key="btn-primary" onClick={props.onFooterButtonClick}>
                    Primary
                  </Button>,
                  <Button
                    key="btn-secondary"
                    priority="secondary"
                    purpose="passive"
                    onClick={props.onFooterButtonClick}
                  >
                    Secondary
// ...
```

### No Overflow Button Theme

```tsx
() => {
  return (
    <div>
      <TrowserMixin>
        {(props: TrowserMixinProps) => {
          return (
            <div>
              <Button purpose="standard" onClick={props.onShowTrowser}>
                Basic Trowser with no Overflow Button on Mobile
              </Button>
              <Trowser
                hideOverflow
                dismissible
                automationId="Default_Theme"
                open={props.open}
                title="Basic Trowser with no Overflow Button on Mobile"
                footerButton={[
                  <Button
                    key="btn-primary"
                    purpose="standard"
                    onClick={props.onFooterButtonClick}
                  >
                    Primary
                  </Button>
                ]}
                onShow={action('Trowser is showing')}
                onClose={props.onCloseTrowser}
              >
                <section>
                  <div>
                    <img
                      style={{ width: '100%' }}
                      alt=""
                      src="https://plugin.intuitcdn.net/qbo-qblive-ui/happy_family_without_logo.e244f900.png"
                    />
                    <p style={{ textAlign: 'center' }}>
                      This full-screen modal is the right fit when customers
                      need to create, view, or edit a transaction.
                    </p>
                    <p style={{ textAlign: 'center' }}>
                      Use a trowser when the user needs to fill out a complex
                      form. The trowser includes a header and a sticky footer.
                      The trowser&apos;s sticky title or header remains
                      secondary to the global header, even though it might lead
                      to some of the same places (such as help and settings).
                    </p>
                    <p style={{ textAlign: 'center' }}>
                      The X in the corner enables users to close the trowser and
                      return to where they started. Users can also close the
                      trowser via the escape key. By default the trowser would
                      focus on input element in the content.
                    </p>
                    <div
                      style={{
                        display: 'flex',
                        alignItems: 'center',
                        justifyContent: 'center'
                      }}
                    >
                      <Dropdown
                        label="Does the example help"
                        onChange={action('onChange')}
                      >
                        <MenuItem value="1">YES</MenuItem>
                        <MenuItem value="2">NO</MenuItem>
                        <MenuItem value="3">IMPROVISE</MenuItem>
                      </Dropdown>
                    </div>
                  </div>
                </section>
              </Trowser>
            </div>
          );
        }}
      </TrowserMixin>
    </div>
  );
}
```

