### Target Element Repositioning

```tsx
() => {
  const [activeDiv, setActiveDiv] = useState('div1');

  const divs = [
    { id: 'div1', label: 'Div 1', left: '50px', top: '50px' },
    { id: 'div2', label: 'Div 2', left: '200px', top: '50px' },
    { id: 'div3', label: 'Div 3', left: '350px', top: '50px' }
  ];

  const currentIndex = divs.findIndex((div) => div.id === activeDiv);

  const nextTarget = () => {
    const nextIndex = (currentIndex + 1) % divs.length;
    setActiveDiv(divs[nextIndex].id);
  };

  const prevTarget = () => {
    const prevIndex = currentIndex === 0 ? divs.length - 1 : currentIndex - 1;
    setActiveDiv(divs[prevIndex].id);
  };

  return (
    <div style={{ padding: '20px' }}>
      <div
        style={{
          position: 'relative',
          height: '300px'
        }}
      >
        {divs.map((div) => (
          <div
            key={div.id}
            id={div.id}
            data-id={div.id}
            style={{
              position: 'absolute',
              left: div.left,
              top: div.top,
              width: '120px',
              height: '80px',
              backgroundColor: activeDiv === div.id ? '#0070f3' : '#e0e0e0',
              color: activeDiv === div.id ? 'white' : '#333',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              borderRadius: '8px',
              cursor: 'pointer',
              fontSize: '14px',
              fontWeight: 'bold',
              transition: 'background-color 0.3s ease-in-out'
            }}
            tabIndex={0}
            role="button"
            aria-label={`Select ${div.label}`}
            onClick={() => setActiveDiv(div.id)}
            onKeyDown={(e) => {
              if (e.key === 'Enter' || e.key === ' ') {
                setActiveDiv(div.id);
              }
            }}
          >
            {div.label}
          </div>
        ))}
      </div>

      <GuidanceTooltip
        dismissible
