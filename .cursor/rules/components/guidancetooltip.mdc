### Target Element With Position Example

```tsx
(props: Themeable) => {
  const [open, setOpen] = useState(false);
  const [position, setPosition] = useState<Positions | undefined>(undefined);
  const [alignment, setAlignment] = useState<Alignments | undefined>(undefined);
  const [target, setTarget] = useState<Element | Text | null>(null);
  const { currentTheme, currentColorScheme } = useTheme(props);

  const buttonRefTop = React.createRef<HTMLButtonElement>();
  const buttonRefLeft = React.createRef<HTMLButtonElement>();

  const handleClick = (
    p: Positions,
    a: Alignments,
    buttonRef: React.MutableRefObject<HTMLElement>
  ) => {
    // eslint-disable-next-line react/no-find-dom-node
    const newTarget = ReactDOM.findDOMNode(buttonRef.current);
    setTarget(newTarget);
    setOpen(true);
    setPosition(p);
    setAlignment(a);
  };

  const handleClose = () => {
    setOpen(false);
  };

  return (
    <div>
      <Button
        innerRef={buttonRefTop}
        className="guidanceTooltipBasicExample"
        onClick={() =>
          handleClick(
            'bottom',
            'center',
            buttonRefTop as React.MutableRefObject<HTMLElement>
          )
        }
      >
        Bottom position/Center Alignment
      </Button>
      <div style={{ marginTop: '50px' }} />
      <Button
        innerRef={buttonRefLeft}
        className="guidanceTooltipBasicExample"
        onClick={() =>
          handleClick(
            'right',
            'middle',
            buttonRefLeft as React.MutableRefObject<HTMLElement>
          )
        }
      >
        Right position/Middle Alignment
      </Button>
      <GuidanceTooltip
        autoFocus
        title="Some sort of title"
        open={open}
        targetElement={target as ReactNode}
        position={position}
        alignment={alignment}
        message={
          <div>
            <span>This is position example.</span>
            <Link
              complementary
              colorScheme={getAppropiateColorScheme(
                currentColorScheme,
                currentTheme
              )}
              href="https://www.intuit.com"
              aria-label="Learn more about Intuit"
            >
              Link text
            </Link>
          </div>
        }
        onClose={handleClose}
// ...
