## Usage Patterns

### Basic Usage

```tsx
(props: Themeable) => {
  const [open, setOpen] = useState(false);
  const { currentTheme, currentColorScheme } = useTheme(props);

  const handleClick = () => {
    setOpen(!open);
  };

  const handleClose = () => {
    setOpen(false);
  };

  return (
    <div>
      <GuidanceTooltip
        autoFocus
        title="Some sort of title"
        open={open}
        message={
          <div>
            <span>This is default example.</span>
            <Link
              colorScheme={getAppropiateColorScheme(
                currentColorScheme,
                currentTheme
              )}
              href="https://www.intuit.com"
              aria-label="Learn more about Intuit"
            >
              Link text
            </Link>
          </div>
        }
        onClose={handleClose}
      >
        <Button className="guidanceTooltipBasicExample" onClick={handleClick}>
          Button example
        </Button>
      </GuidanceTooltip>
    </div>
  );
}
```

