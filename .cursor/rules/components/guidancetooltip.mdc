### Focus

```tsx
() => {
  const [open, setOpen] = useState(false);
  const handleFocus = () => {
    setOpen(true);
  };

  const handleBlur = () => {
    setOpen(false);
  };

  return (
    <div>
      <GuidanceTooltip
        title="Right position, Top alignment"
        position="right"
        alignment="top"
        dismissible={false}
        open={open}
        message={
          <div>
            <span>
              GuidanceTooltip is responsive and will reposition itself to the
              bottom center to fit when browser is resize to smaller size.
            </span>
          </div>
        }
      >
        <TextField
          id="focus"
          label="focus"
          onFocus={handleFocus}
          onBlur={handleBlur}
        />
      </GuidanceTooltip>
    </div>
  );
}
```

