# GuidanceTooltip

Welcome to `GuidanceTooltip` component.

## Installation & Import

```bash
yarn add @ids-ts/guidance-tooltip
```

```tsx
import { GuidanceTooltip } from '@ids-ts/guidance-tooltip';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `alignment` | `Alignments` | Yes | Tooltip alignment (e.g., `'top'`, `'bottom'`, `'left'`, `'right'`). |
| `animationOn` | `boolean` | Yes | - |
| `autoFocus` | `boolean` | Yes | - |
| `automationId` | `string` | No | Test automation ID. |
| `dismissible` | `boolean` | Yes | - |
| `enableClickAway` | `boolean` | Yes | - |
| `index` | `number` | No | index of the tooltip when used in Guided Tour |
| `message` | `string | React.ReactNode` | No | - |
| `offsetX` | `number` | Yes | - |
| `offsetY` | `number` | Yes | - |
| `onClose` | `React.ReactEventHandler` | No | On close callback. |
| `open` | `boolean` | Yes | - |
| `position` | `Positions` | Yes | Tooltip position: `'top'`, `'bottom'`, `'left'`, `'right'`. |
| `preventOverflow` | `an object variable` | Yes | - |
| `preventOverflow` | `PreventOverflow` | No | - |
| `stylePosition` | `React.CSSProperties` | No | * The optional styles applied to the position node wrapped around the root node. |
| `targetElement` | `HTMLElement` | Yes | The DOM element the tooltip is anchored to. |
| `title` | `string` | No | Header text displayed in the tooltip. |
| `tooltipOffsetSkidding` | `number` | No | Cross-axis pixel offset of the tooltip popup. |
| `tooltipOffsetDistance` | `number` | No | Main-axis pixel offset of the tooltip popup. |
| `activeElement` | `HTMLElement` | No | Element to focus when the tooltip closes. |
| `usedForGuidedTour` | `boolean` | No | flag used to apply guidedTourQuickbooks theme |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface GuidanceTooltipProps
  extends Omit<ThemeableElement<'div'>, 'targetElement'> {
  /**
   * Alignment of tooltip to target.
   * alignment: string of alignments
   * vertical alignments: top, bottom, middle
   * horizontal alignments: left, right, center
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   * If multiple given, the first or the one with enough space will be chosen.
   *
   * @default 'bottom'
   */
  alignment: Alignments;
  /**
   * Whether animation is turned on.
   *
   * @default true
   */
  animationOn: boolean;
  /**
   * Whether focus should move inside the tooltip once it is opened.
   *
   * @default false
   */
  autoFocus: boolean;
  /** Test automation ID. */
  automationId?: string;
  /**
   * Shows close icon which allows the component to be closed.
   *
   * @default true
   */
  dismissible: boolean;
  /**
   * Enable close event on click away.
   *
   * @default false
   */
  enableClickAway: boolean;
  /** index of the tooltip when used in Guided Tour */
  index?: number;
  /**
   * Content that needs to be displayed under the titleText.
   * Content should be 150 characters or less.
   */
  message?: string | React.ReactNode;
  /**
   * Offset tooltip on X axis
   *
   * @default 0
   * @deprecated Please use tooltipOffsetSkidding instead
   */
  offsetX: number;
  /**
   * Offset tooltip on Y axis
   *
   * @default 0
   * @deprecated Please use tooltipOffsetDistance instead
   */
  offsetY: number;
  /** On close callback. */
  onClose?: React.ReactEventHandler;
  /**
   * Whether component open.
   *
   * @default false
   */
  open: boolean;
  /**
   * Position for tooltip to be placed.
   * position: string of positions to try
   * vertical positions: top, bottom
   * horizontal positions: left, right
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   * If multiple given, the first or the one with enough space will be chosen.
   *
   * @default 'right'
   */
  position: Positions;
  /**
   * preventOverflow: an object variable; used to prevent GuidanceTooltip from being positioned outside the boundary.
   *  More detail in @ids-ts/position preventOverflow API document.
   */
  preventOverflow?: PreventOverflow;
  /**
   * The optional styles applied to the position node wrapped around the root node.
   */
  stylePosition?: React.CSSProperties;
  /**
   * targetElement: a HTML DOM element
   * The HTML DOM element to be used as the target reference.
   */
  targetElement?: React.ReactNode | string;
  /**
   * Text to display as a heading for the message.
   * Title should be 30 characters or less.
   */
  title: string;
  /**
   * tooltipOffsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  tooltipOffsetSkidding: number;
  /**
   * tooltipOffsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  tooltipOffsetDistance: number;
  /**
   * activeElement: a HTML DOM element
   * The HTML DOM element to be used to focus on when tooltip closed.
   */
  activeElement?: HTMLElement | null;
  /** flag used to apply guidedTourQuickbooks theme */
  usedForGuidedTour?: boolean;
}
```

</details>

