# SplitButton

A IDS split button helps consolidate multiple actions while surfacing the most common action used by customers. It reduces the amount of visual noise, especially for complex use cases like bulk actions for tables. Use it when there are two or more non-primary actions that are needed for the context.

## Installation & Import

```bash
yarn add @ids-ts/split-button
```

```tsx
import { SplitButton } from '@ids-ts/split-button';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `automationId` | `string` | No | Test automation ID. |
| `buttonPriority` | `ButtonPriority` | No | - |
| `buttonPurpose` | `ButtonPurpose` | No | - |
| `buttonSize` | `ButtonSize` | No | - |
| `children` | `ReactElement<MenuItemProps> \| ReactElement<MenuItemProps>[]` | No | MenuItem children for the dropdown menu. |
| `disabled` | `boolean` | No | Disable the actionable item. |
| `label` | `string` | Yes | Label used to display action choices. |
| `menuAlignment` | `'right' | 'left'` | No | - |
| `menuOffsetSkidding` | `number` | No | Cross-axis pixel offset of the dropdown menu. |
| `menuOffsetDistance` | `number` | No | Main-axis pixel offset of the dropdown menu. |
| `menuOffsetX` | `number` | No | X-axis pixel offset of the dropdown menu. |
| `menuOffsetY` | `number` | No | Y-axis pixel offset of the dropdown menu. |
| `onClick` | `(e: React.MouseEvent<HTMLButtonElement>) => void` | No | Called when the main button is clicked. |
| `onSelect` | `(e: React.MouseEvent<HTMLElement> \| React.KeyboardEvent) => void` | No | Called when a dropdown action is selected. |
| `preventMenuOverflow` | `an object variable` | Yes | - |
| `preventMenuOverflow` | `PreventOverflow` | No | - |
| `stylePosition` | `React.CSSProperties` | No | The optional styles applied to the position node wrapped around the root node. |
| `positionDependencies` | `unknown[]` | No | - |
| `isLoading` | `boolean` | No | * Specifies if the button is isLoading state. Loads a spinner |
| `loadingComponent` | `JSX.Element` | No | - |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface SplitButtonProps
  extends Omit<ThemeableElement<'div'>, 'onClick' | 'onSelect'> {
  /** Test  automation ID. */
  automationId?: string;
  /**
   * Specifies Button priority, 'primary', 'secondary', 'tertiary'
   *
   * @default 'primary'
   */
  buttonPriority?: ButtonPriority;
  /**
   * Specifies Button purpose, 'standard', 'passive', 'complementary', 'ai'
   *
   * @default 'standard'
   */
  buttonPurpose?: ButtonPurpose;
  /**
   * Size of button - size of button small, medium, large
   *
   * @default 'medium'
   */
  buttonSize?: ButtonSize;
  /** Consumes menu item(s) to be displayed as additional actions. */
  children?:
    | React.ReactElement<MenuItemProps>
    | React.ReactElement<MenuItemProps>[];
  /** Disable the actionable item. */
  disabled?: boolean;
  /** Label used to display action choices. */
  label: string;
  /** */
  menuAlignment?: 'right' | 'left';
  /**
   * menuOffsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  menuOffsetSkidding?: number;
  /**
   * menuOffsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  menuOffsetDistance?: number;
  /**
   * menuOffsetX: the x axis pixel distance that the popup should be offset from targetElement
   *
   * @deprecated Please use menuOffsetSkidding instead
   */
  menuOffsetX?: number;
  /**
   * menuOffsetY: the y axis pixel distance that the popup should be offset from targetElement
   *
   * @deprecated Please use menuOffsetDistance instead
   */
  menuOffsetY?: number;
  /** A callback function that is fired when a button has been clicked. */
  onClick?: (
    e:
      | React.MouseEvent<HTMLButtonElement>
      | React.KeyboardEvent<HTMLButtonElement>
  ) => void;
  /** A Callback function that is fired when an action has been selected. */
  onSelect?: (
    e: React.MouseEvent<HTMLElement> | React.KeyboardEvent<HTMLElement>
  ) => void;
  /**
   * preventMenuOverflow: an object variable; used to prevent SplitButton Menu from being positioned outside the boundary.
   * More detail in @ids-ts/position preventOverflow API document.
   */
  preventMenuOverflow?: PreventOverflow;
  /** The optional styles applied to the position node wrapped around the root node. */
  stylePosition?: React.CSSProperties;
  /**
   * Dependencies that will cause the Menu's popperjs instance to recalculate its position, whenever any of the dependencies change.
   * These dependencies work the same way as the list you would pass into a React useEffect()
   */
  positionDependencies?: unknown[];

  /**
   * Specifies if the button is isLoading state. Loads a spinner
   */
  isLoading?: boolean;

  /**
   * Specify the component to render when isLoading === true
   * When not specified, will render children no matter the value of isLoading
   */
  loadingComponent?: JSX.Element;
}

export type ButtonPriority = Filter<Priority, 'primary' | 'secondary'>;

export type ButtonPurpose = Filter<
  Purpose,
  'standard' | 'passive' | 'complementary' | 'ai'
>;
```

</details>

