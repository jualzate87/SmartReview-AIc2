## Usage Patterns

### Dark Background

```tsx
() => (
  <div
    style={{
      backgroundColor: '#393a3d',
      padding: '20px'
    }}
  >
    <div style={{ display: 'flex', flexDirection: 'column', gap: '20px' }}>
      <SplitButton label="Add trip (Standard styling)">
        <MenuItem value="View">View trip</MenuItem>
        <MenuItem value="Cancel">Cancel trip</MenuItem>
        <MenuItem value="Manage">Manage trip</MenuItem>
        <MenuItem value="Download">Download itinerary</MenuItem>
      </SplitButton>
      <SplitButton
        label="Add trip (Standard secondary styling)"
        buttonPriority="secondary"
      >
        <MenuItem value="View">View trip</MenuItem>
        <MenuItem value="Cancel">Cancel trip</MenuItem>
        <MenuItem value="Manage">Manage trip</MenuItem>
        <MenuItem value="Download">Download itinerary</MenuItem>
      </SplitButton>
      <SplitButton label="Add trip (Passive styling)" buttonPurpose="passive">
        <MenuItem value="View">View trip</MenuItem>
        <MenuItem value="Cancel">Cancel trip</MenuItem>
        <MenuItem value="Manage">Manage trip</MenuItem>
        <MenuItem value="Download">Download itinerary</MenuItem>
      </SplitButton>
      <SplitButton
        label="Add trip  (Passive secondary styling)"
        buttonPurpose="passive"
        buttonPriority="secondary"
      >
        <MenuItem value="View">View trip</MenuItem>
        <MenuItem value="Cancel">Cancel trip</MenuItem>
        <MenuItem value="Manage">Manage trip</MenuItem>
        <MenuItem value="Download">Download itinerary</MenuItem>
      </SplitButton>
    </div>
  </div>
)
```

### Update Position

```tsx
() => {
  const [y, setY] = useState(0);

  useEffect(() => {
    const timerId = setInterval(() => {
      setY((oldY) => (oldY + 100) % 600);
    }, 1500);

    return () => {
      clearInterval(timerId);
    };
  }, []);

  return (
    <SplitButton
      label="Add trip (Standard styling)"
      positionDependencies={[y]}
      automationId="primaryAction"
      style={{
        marginTop: y
      }}
      onClick={action('SplitButton clicked')}
      onSelect={action('MenuItem clicked')}
    >
      <MenuItem value="View">View trip</MenuItem>
      <MenuItem value="Cancel">Cancel trip</MenuItem>
      <MenuItem value="Manage">Manage trip</MenuItem>
      <MenuItem value="Download">Download itinerary</MenuItem>
    </SplitButton>
  );
}
```

