### Group Default Value Controlled

```tsx
() => {
  const [value, setValue] = useState('1');

  return (
    <RadioGroup
      name="controlledRb"
      label="Radio Group Default Value Controlled Example - Value set in the background depending on the choice made"
      value={value}
      onChange={(e: any) => {
        action('Clicked')(e.target.value);
        setValue(e.target.value);
      }}
    >
      <Radio value="1">Set value to 1</Radio>
      <Radio value="2">Set value to 2</Radio>
      <Radio value="3">Set value to 3</Radio>
    </RadioGroup>
  );
}
```

