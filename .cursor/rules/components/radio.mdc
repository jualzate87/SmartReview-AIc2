### Group Using Options

```tsx
() => (
  <>
    <RadioGroup
      name="optionsRb"
      options={['A', 'B', 'C']}
      defaultValue="A"
      label="Option Strings"
    />
    <br />
    <RadioGroup
      options={[
        { label: 'A', value: 'a' },
        { label: 'B', value: 'b' },
        { label: 'C', value: 'c' }
      ]}
      defaultValue="c"
      label="Option Objects"
      onMouseEnter={action('here')}
    />
  </>
)
```

