<details>
<summary>Full RadioGroup TypeScript Interface</summary>

```typescript
export interface RadioGroupProps
  extends Omit<ThemeableElement<'fieldset'>, 'onChange'> {
  /** aria-describedby attribute to handle non-semantic use case */
  'aria-describedby'?: string;
  /** A list of <Radio> */
  children?: ReactElement | ReactElement[];
  /** Specifies the initial state: whether or not a Radio is checked. */
  defaultValue?: string | string[];
  /**
   * Disable all radio buttons.
   *
   * @default false
   */
  disabled?: boolean;
  /** Helper text for the Radio group. Can be a React node. */
  helperText?: string | ReactNode;
  /** Label for the Radio group. Can be a React node. */
  label?: string | ReactNode;
  /** The name that will be applied to all child Radio buttons. */
  name?: string;
  /** Callback function that is fired when a Radio button has been selected. */
  onChange?: RadioOnChangeType;
  /**
   * Set the children Radio by using an array of values or an array of objects.
   *
   * @default []
   */
  options?: string[] | RadioOptionType[];
  /** Affects size of text rendered next to checkbox
   *
   * @default 'medium'
   *
   */
  size?: 'small' | 'medium';
  /** The value used to currently select the Radio. */
  value?: string | string[];
  /**
   * Determines the type of Validation Message : ['error', 'warning', 'success', 'invalid', 'info', '']
   *
   * @default ''
   */
  validationType?: InlineValidationType;
  /** Validation Message */
  validationMessage?: string;
  /**
   * Layout type vertical or horizontal.
   *
   * @default false
   */
  vertical?: boolean;
}

export interface RadioOptionType {
  /** Radio description prop */
  description?: ReactNode | string;
  /** Radio disabled prop */
  disabled?: boolean;
  /** Radio label prop */
  label?: string;
  /** Radio onChange prop */
  onChange?: RadioOnChangeType;
  /** Radio value prop */
  value: string;
}
```

</details>

