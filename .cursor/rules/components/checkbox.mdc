## Usage Patterns

### Showcase

```tsx
() => (
  <div className={styles.exampleCheckbox}>
    <div data-automation-id="checkbox-basic">
      <h3 id="checkbox-1">Checkbox: Basic</h3>
      <Checkbox
        onChange={(e) => action('checkbox 1 checked: ')(e.target.checked)}
      >
```

### Checkbox Group Playground

```tsx
({
  disableCheckbox3,
  disabled,
  helperText,
  label,
  size,
  useOptions,
  validationMessage,
  validationType,
  vertical
}) => {
  const labelOptions = ['Pineapple', 'Grapes', 'Eggplant'];

  const [validationStatus, setValidationStatus] = useState(validationType);

  const onChange = (checkboxName: number | string, value: any) => {
    action(`checkbox '${checkboxName}' checked: `)(value);
    if (typeof value === 'object') {
      setValidationStatus(() => (value.length > 0 ? '' : validationType));
    } else {
      setValidationStatus(() => (value ? '' : validationType));
    }
  };

  if (!useOptions) {
    return (
      <CheckboxGroup
        vertical={vertical}
        disabled={disabled}
        size={size}
        helperText={helperText}
        label={label}
        validationType={validationStatus}
        validationMessage={validationMessage}
        name="fruitLabels"
        onChange={(value) => onChange('group', value)}
      >
        <Checkbox
          value="Pineapple"
          onChange={(e) => onChange('1', e.target.checked)}
        >
          Pineapple
        </Checkbox>
        <Checkbox
          value="Grapes"
          onChange={(e) => onChange('2', e.target.checked)}
        >
          Grapes
        </Checkbox>
        <Checkbox
          disabled={disableCheckbox3}
          value="Eggplant"
          onChange={(e) => onChange('2', e.target.checked)}
        >
          Eggplant
        </Checkbox>
      </CheckboxGroup>
    );
  }

  return (
    <CheckboxGroup
      vertical={vertical}
      disabled={disabled}
      helperText={helperText}
      label={label}
      options={labelOptions}
      size={size}
      validationType={validationStatus}
      validationMessage={validationMessage}
      name="fruitLabels"
      onChange={(value) => onChange('group', value)}
    />
  );
}
```

## Accessibility

### Keyboard Navigation

- **Space** key checks/unchecks the checkbox
- **Tab** should navigate focus to the next checkbox in the CheckBoxGroup.
- **Shift + Tab** should navigate focus to the previous checkbox in the CheckBoxGroup.

