  /**
   * Disable the checkbox.
   *
   * @default false
   */
  disabled?: boolean;
  /**
   * Specifies when type is checkbox and in a indeterminate state [-].
   *
   * @default false
   */
  indeterminate?: boolean;
  /** a name assign to the checkbox input */
  name?: string;
  /** Callback function that is fired when a Checkbox has been blurred. */
  onBlur?: FocusEventHandler<HTMLInputElement>;
  /** Callback function with customize event object that is fired when a Checkbox has been checked.  */
  onChange?: CheckboxOnChangeType;
  /** Callback function that is fired when a Checkbox has been clicked. */
  onClick?: MouseEventHandler<HTMLInputElement>;
  /** Callback function that is fired when a Checkbox has been focused. */
  onFocus?: FocusEventHandler<HTMLInputElement>;
  /** Affects size of text rendered next to checkbox
   *
   * @default 'medium'
   *
   */
  size?: 'small' | 'medium';
  /** tab-index assign to the checkbox input. */
  tabIndex?: number;
  /** Validation Message. */
  validationMessage?: string;
  /**
   * Validation Type from InlineValidationMessage: 'error', 'warning', 'success', 'invalid', 'info', or ''
   *
   * @default ''
   */
  validationType?: InlineValidationType;
  /** Checkbox current value. */
  value?: string;
}

export interface CheckboxOnChangeType {
  (e: CheckboxOnChangeEventType): void;
}

export interface CheckboxOnChangeEventType {
  /** a modify event target */
  target: {
    /** a event target check value */
    checked?: boolean;
  };
  stopPropagation?(): void;
  preventDefault?(): void;
}
