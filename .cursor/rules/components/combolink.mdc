## Usage Patterns

### Showcase

```tsx
() => {
  const options = ['Apple', 'Peach', 'Banana', 'Orange'];
  const menuItems = getMenuItems(options, 4);
  const [label, setLabel] = useState('Label');
  const handleSelect = (event: ReactComboLinkEvent) => {
    const { value } = event.target as HTMLInputElement;
    setLabel(value);
    action(`firing from onSelect in playground: ${value}`)();
  };

  return (
    <div className={styles.showcase}>
      <div>
        Mini ComboLink
        <ComboLink
          size="mini"
          label={label}
          aria-label="mini-fruit-selection-combolink"
          onSelect={handleSelect}
        >
          {menuItems}
        </ComboLink>
      </div>
      <div>
        Standard ComboLink
        <ComboLink
          size="standard"
          label={label}
          aria-label="standard-fruit-selection-combolink"
          onSelect={handleSelect}
        >
          {menuItems}
        </ComboLink>
      </div>
      <div>
        Mini Disabled ComboLink
        <ComboLink
          disabled
          size="mini"
          label={label}
          aria-label="mini-disabled-fruit-selection-combolink"
        >
          {menuItems}
        </ComboLink>
      </div>
      <div>
        Standard Disabled ComboLink
        <ComboLink
          disabled
          size="standard"
          label={label}
          aria-label="standard-disabled-fruit-selection-combolink"
        >
          {menuItems}
        </ComboLink>
      </div>
      <div>
        Prevent Menu Select
        <ComboLink
          preventMenuSelect
          size="mini"
          label={label}
          aria-label="prevent-menuSelect-fruit-selection-combolink"
        >
          {menuItems}
        </ComboLink>
      </div>
    </div>
  );
}
```

