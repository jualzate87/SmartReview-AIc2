<details>
<summary>Full DrawerContent TypeScript Interface</summary>

```typescript
export interface DrawerContentProps extends Element<'section'> {
  /** Internal use only: Determine if the drawer should automatically have focus after being opened */
  autoFocus?: boolean;
  /** Whether to show dissolve section or not */
  dissolveSection?: boolean;
  /** Internal use only: Whether the drawer is opened or not */
  open?: boolean;
  /** Internal use only: restoreFocus prop to allow focus back on trigger button */
  restoreFocus?: boolean;
  /**
   * Determines whether the user scrolled to the top
   * Note: this is handled automatically, do not specify this manually.
   */
  scrolledTop?: () => void;
  /**
   * Determines if content is scrolling
   * Note: this is handled automatically, do not specify this manually.
   */
  scrolling?: () => void;
  /** Size of drawer */
  size?: DrawerSize;
  /** An optional large title to show above the content */
  title?: string;
}

export type DrawerSize = 'xsmall' | 'small' | 'medium' | 'large';
```

</details>

