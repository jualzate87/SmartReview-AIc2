## Usage Patterns

### Playground

```tsx
({
  autoFocus,
  backActionLabel,
  backdrop,
  bottomUp,
  center,
  drawerContentTitle,
  drawerHeaderTitle,
  restoreFocus,
  showSearchHeader,
  showStepFlowUsage,
  size
}) => {
  const [open, setOpen] = useState(false);
  const [openStep, setOpenStep] = useState(false);

  const openDrawer = () => setOpen(true);
  const closeDrawer = () => setOpen(false);

  const closeStepDrawer = () => setOpenStep(false);
  const openStepDrawer = () => setOpenStep(true);

  return (
    <>
      <Button id="open_drawer_sizes_example" onClick={openDrawer}>
        Open drawer
      </Button>
      <Drawer
        bottomUp={bottomUp}
        backdrop={backdrop}
        open={open}
        autoFocus={autoFocus}
        restoreFocus={restoreFocus}
        size={size}
        onClose={closeDrawer}
        onShow={openDrawer}
      >
        {showSearchHeader ? (
          <DrawerSearchHeader
            backActionLabel={backActionLabel}
            onClose={closeDrawer}
          />
        ) : (
          <DrawerHeader
            backActionLabel={backActionLabel}
            title={drawerHeaderTitle}
            onClose={closeDrawer}
          />
        )}
        <DrawerContent title={drawerContentTitle}>
          {showSearchHeader ? <SearchDrawerContent /> : <DrawerChildren />}
          {showStepFlowUsage && (
            <Button onClick={openStepDrawer}>Go To Level 2</Button>
          )}
        </DrawerContent>
        <DrawerFooter
          center={center}
          footerPrimaryAction={
            <Button purpose="standard" onClick={closeDrawer}>
              Primary
            </Button>
          }
          footerSecondaryAction={
            <Button purpose="standard" priority="secondary">
              Secondary
            </Button>
          }
          footerTertiaryAction={
            <Button purpose="standard" priority="tertiary">
              Tertiary
            </Button>
          }
        />
      </Drawer>
      {showStepFlowUsage && (
        <Drawer stepFlow open={openStep} onClose={closeStepDrawer}>
          <DrawerHeader
            title="Second Page"
            backActionLabel="Go back"
            onBackActionClick={closeStepDrawer}
// ...
```

