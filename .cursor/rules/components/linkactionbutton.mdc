## Usage Patterns

### Basic Usage

```tsx
() => {
  const largeMargin = { margin: '20px' };

  return (
    <div>
      <div style={largeMargin}>
        <LinkActionButton
          size="medium"
          onClick={action('Add functionality for link action button')}
        >
          Close - Medium
        </LinkActionButton>
      </div>
      <div style={largeMargin}>
        <LinkActionButton
          size="small"
          onClick={action('Add functionality for link action button')}
        >
          Dismiss - Small
        </LinkActionButton>
      </div>
      <div style={largeMargin}>
        <LinkActionButton
          size="extraSmall"
          onClick={action('Add functionality for link action button')}
        >
          Undo - Extra Small
        </LinkActionButton>
      </div>
    </div>
  );
}
```

### With Variant

```tsx
() => {
  const largeMargin = { margin: '20px' };

  return (
    <div>
      <div style={largeMargin}>
        <LinkActionButton
          variant="secondary"
          onClick={action('Add functionality for link action button')}
        >
          Link Text
        </LinkActionButton>
      </div>
      <div style={largeMargin}>
        <LinkActionButton
          variant="standalone"
          onClick={action('Add functionality for link action button')}
        >
          Link Text
        </LinkActionButton>
      </div>
    </div>
  );
}
```

## Code Example

```tsx
import React from 'react';
import LinkActionButton from '@ids-ts/link-action-button';

const LinkActionButtonExample = () => (
  <LinkActionButton
    size="medium"
    onClick={() => console.log('Add functionality for link action button')}
  >
    Close - Medium
  </LinkActionButton>
);

export default LinkActionButtonExample;
```

