<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface AccordionProps
  extends AccordionContextProps,
    Omit<ThemeableElement<'section'>, 'onChange'> {
  /** Element ID */
  id?: string;
  /** Accordion Item ref object */
  ref?: RefObject<HTMLDivElement>;
  /**
   * Change listener callback function
   * It will be called when an AccordionItem is expanded/collapsed
   *
   * Function Parameters:
   * It will be called with a json object as a parameter with following properties
   * - index: number, to identify the AccordionItem
   * - id: string, to identify the AccordionItem
   * - expanded: bool, indicating whether the item is expanded or collapsed. NOTE: the boolean
   *   value is the negation of the actual expanded state (i.e. false when the item is expanded).
   *   This is intentionally left unfixed because it would cause substantial impact
   *
   * props.onChange({ index, id, expanded });
   */
  onChange?: (infoObject?: OnChangeInfoType) => void;
  /** Array of <AccordionItem /> */
  children?: React.ReactElement | React.ReactElement[];
}

export type OnChangeInfoType = {
  /** index of AccordionItem */
  index: number;
  /** id: string, to identify the AccordionItem */
  id?: string;
  /** expanded: bool, indicating whether the item is expanded or collapsed */
  expanded: boolean;
}

export interface AccordionContextProps {
  /** Allow multiple accordion sections to be expanded at the same time */
  allowMultipleExpanded?: boolean;
  /**
   * Allows all sections to be collapsed.
   * Default value is false, which will enforce at least one section to be expanded.
   */
  allowZeroExpanded?: boolean;
  /** Prop to specify if chevron position is to the left, right or split */
  chevronPosition?: 'left' | 'right' | 'split';
  /** className prop to allow customizing the style for Accordion */
  className?: string;
  /** Flag to indicate if Accordion container is card type. */
  isCardTypeContainer?: boolean;
  /**
   * Accordion items can be stacked as row or list.
   * This prop would help cascade that information.
   */
  stackingType?: 'list' | 'row';
  /** size of accordion. size value would be applied to both chevron icon and title of accordion */
  size?: 'x-small' | 'small' | 'medium' | 'large' | 'x-large';
  /**
   * Signifier label is additional text control for AccordionItem header.
   */
  signifierLabel?: string;
  /**
   * Alignment for signifierLabel. Supported values are left, right, center.
   */
  signifierLabelAlignment?: 'left' | 'center' | 'right';
  /**
   * Accordion needs to support blue color variant for signifierLabel along with grey.
   * This flag would allow it to be specified.
   */
  useSignifierLinkAsBlue?: boolean;
  /** Predefined variants and they can be text or card */
  variant?: 'text' | 'standard' | 'card';
}
```

</details>

