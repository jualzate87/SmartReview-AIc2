### Controlled Accordion Item State

```tsx
() => {
  const [expanded, setExpanded] = useState(false);
  const toggleExpanded = () => setExpanded(!expanded);
  const handleChange = (e: OnChangeInfoType | undefined) => {
    if (e?.expanded !== undefined) setExpanded(e.expanded);
  };

  return (
    <>
      <Button aria-expanded={expanded} onClick={toggleExpanded}>
        Learn about aria-multiline
      </Button>
      <br />
      <Accordion allowZeroExpanded variant="text" onChange={handleChange}>
        <AccordionItem expanded={expanded}>
          <AccordionItemHeader>Learn about aria-multiline</AccordionItemHeader>
          <AccordionItemBody>
            <H3>aria-multiline</H3>
            <B2>
              The aria-multiline attribute indicates whether a textbox accepts
              multiple lines of input or only a single line.
            </B2>
            <H3>Description</H3>
            <B2>
              The default behavior of the Enter or Return key differs between
              single-line and multi-line text fields. When user focus is in a
              single-line &lt;input type=&quot;text&quot;&gt;, an Enter or
              Return keystroke usually submits the form.
            </B2>
          </AccordionItemBody>
        </AccordionItem>
      </Accordion>
    </>
  );
}
```

### Add Accordions Example

```tsx
() => {
  const [expanded, setExpanded] = useState(false);
  const [accordion, setAccordion] = useState([
    <AccordionItem key={0}>
      <AccordionItemHeader>Accordion Item 0</AccordionItemHeader>
      <AccordionItemBody>Accordion Item 0</AccordionItemBody>
    </AccordionItem>
  ]);
  const handleChange = (e: OnChangeInfoType | undefined) => {
    if (e?.expanded !== undefined) setExpanded(e.expanded);
  };

  const handleAddToTop = () => {
    setAccordion([
      <AccordionItem key={accordion.length}>
        <AccordionItemHeader>{`Accordion Item ${accordion.length}`}</AccordionItemHeader>
        <AccordionItemBody>{`Accordion Item ${accordion.length}`}</AccordionItemBody>
      </AccordionItem>,
      ...accordion
    ]);
  };

  const handleAddToBottom = () => {
    setAccordion([
      ...accordion,
      <AccordionItem key={accordion.length}>
        <AccordionItemHeader>{`Accordion Item ${accordion.length}`}</AccordionItemHeader>
        <AccordionItemBody>{`Accordion Item ${accordion.length}`}</AccordionItemBody>
      </AccordionItem>
    ]);
  };

  return (
    <>
      <Button aria-expanded={expanded} onClick={handleAddToTop}>
        Add Accordion to top
      </Button>
      <Button aria-expanded={expanded} onClick={handleAddToBottom}>
        Add Accordion to bottom
      </Button>
      <br />
      <Accordion
        allowZeroExpanded
        allowMultipleExpanded
        variant="text"
        onChange={handleChange}
      >
        {accordion.map((accordionItem) => {
          return accordionItem;
        })}
      </Accordion>
    </>
  );
}
```

## Guidelines

**Use when:**
- Organizing related information.
- Shortening pages and reducing scrolling when content is lower priority, or not crucial to read or view in full.

**Do not use when:**
- Hiding high priority information or error messages that require an immediate action or attention.


## Accessibility

### Keyboard Navigation

- Pressing `Tab or ArrowKeys` will navigate though different Accordion items while displaying a focus ring.
- Pressing `Enter or SpaceBar` while focusing on an AccordionItem, would expand or collapse the item.
- If an AccordionItem contains any other interactive components, then pressing `Tab` after expanding the item, the focus would be on the interactive component.

### Screen Reader

Accordion is built as single target area and would announce `role, state, value and label`.

## Code Example

```tsx
const ItemExample = ({ title, body, ...props }) => (
  <AccordionItem {...props}>
    <AccordionItemHeader sectionTitle={title} />
    <AccordionItemBody>{body}</AccordionItemBody>
  </AccordionItem>
);

const AccordionExample = () => {
  const arr = [
    { title: 'title1', body: 'body1' },
    { title: 'title2', body: 'body2' }
  ];
  const items = arr.map(({ title, body }) => (
    <ItemExample key={`key-${title}`} title={title} body={body} />
  ));

  return <Accordion variant="standard">{items}</Accordion>;
};
```

