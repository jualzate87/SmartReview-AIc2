## Usage Patterns

### Basic Usage

```tsx
() => {
  const [isOpen, setIsOpen] = useState(false);
  return (
    <>
      <Button onClick={() => setIsOpen(true)}>Open Video Player</Button>
      <Video open={isOpen} url={url} onCloseVideo={() => setIsOpen(false)} />
    </>
  );
}
```

### Only Show Related Videos From Current Channel

```tsx
() => {
  const [isOpen, setIsOpen] = useState(false);
  return (
    <>
      <Button onClick={() => setIsOpen(true)}>Open Video Player</Button>
      <Video
        recFromCurrentChannelOnly
        open={isOpen}
        url={url}
        onCloseVideo={() => setIsOpen(false)}
      />
    </>
  );
}
```

### Aria Label Overwrites

```tsx
() => {
  const [isOpen, setIsOpen] = useState(false);
  return (
    <>
      <Button onClick={() => setIsOpen(true)}>Open Video Player</Button>
      <Video
        open={isOpen}
        url={url}
        minimizeAriaLabel="Overwrite default aria label for making video player small"
        restoreAriaLabel="Overwrite default aria label for making video player large"
        closeAriaLabel="Overwrite default aria label for closing video player"
        onCloseVideo={() => setIsOpen(false)}
      />
    </>
  );
}
```

### Title Overwrite

```tsx
() => {
  const [isOpen, setIsOpen] = useState(false);
  return (
    <>
      <Button onClick={() => setIsOpen(true)}>Open Video Player</Button>
      <Video
        open={isOpen}
        url={url}
        titleText="If provided, then it will replace the existing Youtube video title"
        onCloseVideo={() => setIsOpen(false)}
      />
    </>
  );
}
```

### Multiple Z Indices Example

```tsx
() => {
  const [trowserOpen, setTrowserOpen] = useState(false);
  const [trowserVidOpen, setTrowserVidOpen] = useState(false);
  const [drawerOpen, setDrawerOpen] = useState(false);
  const [drawerVidOpen, setDrawerVidOpen] = useState(false);
  const [modalOpen, setModalOpen] = useState(false);
  const [modalVidOpen, setModalVidOpen] = useState(false);

  return (
    <div>
      <Button
        data-testid="open-trowser-btn-zindice-story"
        onClick={() => setTrowserOpen(true)}
      >
        Open Trowser
      </Button>
      <Trowser
        dismissible
        open={trowserOpen}
        data-testid="trowser-zindice-story"
        onClose={() => setTrowserOpen(false)}
      >
        <Video
          open={trowserVidOpen}
          url={url}
          data-testid="trowser-video-zindice-story"
          onCloseVideo={() => setTrowserVidOpen(false)}
        />
        <Button
          data-testid="open-trowser-video-btn-zindice-story"
          onClick={() => setTrowserVidOpen(true)}
        >
          Open Trowser Video
        </Button>
        <Button
          data-testid="open-drawer-btn-zindice-story"
          onClick={() => setDrawerOpen(true)}
        >
          Open Drawer
        </Button>
        <Drawer
          open={drawerOpen}
          data-testid="drawer-zindice-story"
          onClose={() => setDrawerOpen(false)}
        >
          <DrawerHeader
            title="Drawer Title"
            onClose={() => setDrawerOpen(false)}
          />
          <DrawerContent>
            <Video
              open={drawerVidOpen}
              url={url}
              data-testid="drawer-video-zindice-story"
              onCloseVideo={() => setDrawerVidOpen(false)}
            />
            <Button
              data-testid="open-drawer-video-btn-zindice-story"
              onClick={() => setDrawerVidOpen(true)}
            >
              Open Drawer Video
            </Button>
            <Button
              data-testid="open-modal-btn-zindice-story"
              onClick={() => setModalOpen(true)}
            >
              Open Modal
            </Button>
            <Modal
              dismissible
              open={modalOpen}
              data-testid="modal-zindice-story"
              onClose={() => setModalOpen(false)}
            >
              <ModalContent>
                <Video
                  open={modalVidOpen}
                  url={url}
                  data-testid="modal-video-zindice-story"
                  onCloseVideo={() => setModalVidOpen(false)}
// ...
```

### Playground

```tsx
({
  url,
  minimizeAriaLabel,
  restoreAriaLabel,
  closeAriaLabel,
  titleText
}: VideoControls) => {
  const [isOpen, setIsOpen] = useState(false);

  // There isn't a knob for recFromCurrentChannelOnly because it would require re-instantiation of the YT player if a user has already opened the video.
  // Instead, added a second story highlighting that feature.

  return (
    <>
      <Button onClick={() => setIsOpen(true)}>Open Video Player</Button>
      <Video
        open={isOpen}
        url={url}
        minimizeAriaLabel={minimizeAriaLabel}
        restoreAriaLabel={restoreAriaLabel}
        closeAriaLabel={closeAriaLabel}
        titleText={titleText}
        onCloseVideo={() => setIsOpen(false)}
      />
    </>
  );
}
```

