### Font Size Comparison

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [selectedItem, setSelectedItem] = useState('');
  const [autoFocus, setAutoFocus] = useState(false);

  const handleClose = () => setOpen(false);
  const handleButtonClick = () => setOpen(!open);

  const handleSelect = (e: any) => {
    setSelectedItem(e.target.value);
    setOpen(false);
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (['ArrowDown', ' ', 'Enter'].indexOf(e.key) > -1) {
      e.preventDefault();
      setOpen(true);
      setAutoFocus(true);
    } else if (e.key === 'Tab') {
      setOpen(false);
    } else if (e.key === 'Escape' && open) {
      e.preventDefault();
      handleClose();
    }
  };

  const anchorButton = (
    <Button
      name="buttonToOpen"
      aria-haspopup="true"
      aria-expanded={open}
      className="anchorButton"
      onClick={handleButtonClick}
      onKeyDown={handleKeyDown}
    >
      Choose a Screen Reader
    </Button>
  );

  return (
    <>
      <H3>Font Size Comparison</H3>
      <div style={{ display: 'flex' }}>
        <div style={{ padding: '20px' }}>
          <H4>Small Menu</H4>
          <Menu
            minWidth="99px"
            open={open}
            size="small"
            autoFocus={autoFocus}
            selectedItem={selectedItem}
            anchorElement={anchorButton}
            onSelect={handleSelect}
            onClose={handleClose}
          >
            {menuItems}
          </Menu>
        </div>
        <div style={{ padding: '20px' }}>
          <H4>Medium Menu</H4>
          <Menu
            minWidth="99px"
            open={open}
            size="medium"
            autoFocus={autoFocus}
            selectedItem={selectedItem}
            anchorElement={anchorButton}
            onSelect={handleSelect}
            onClose={handleClose}
          >
            {menuItems}
          </Menu>
        </div>
      </div>
    </>
  );
}
