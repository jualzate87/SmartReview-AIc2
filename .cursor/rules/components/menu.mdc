### Drop Down Text

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [selectedItem, setSelectedItem] = useState('');
  const [textFieldValue, setTextFieldValue] = useState('');
  const [autoFocus, setAutoFocus] = useState(false);
  const inputRef = React.useRef<HTMLInputElement | null>(null);
  const menuListRef = React.useRef<HTMLUListElement | null>(null);

  const handleClick = () => {
    setOpen(!open);
    setAutoFocus(false);
  };

  const handleSelect = (
    e: React.MouseEvent<HTMLElement> | React.KeyboardEvent<HTMLElement>
  ) => {
    setOpen(false);
    setAutoFocus(false);
    // @ts-expect-error: value does not exist on EventTarget
    setSelectedItem(e.target.value);
    // @ts-expect-error: value does not exist on EventTarget
    setTextFieldValue(e.target.value);
    inputRef.current && inputRef.current.focus();
  };

  const handleClose = () => {
    if (open && inputRef.current) {
      setAutoFocus(false);
      setOpen(false);
    }
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'ArrowDown') {
      setAutoFocus(true);
      setOpen(true);
    } else if (e.key === 'Tab') {
      inputRef.current && inputRef.current.blur();
    } else if (e.key === 'Escape') {
      e.preventDefault();
      handleClose();
    }
  };

  const handleChange = (e: React.ChangeEvent) => {
    // @ts-expect-error: value exists on target
    setTextFieldValue(e.target.value);
  };

  const handleBlur = (e: React.FocusEvent) => {
    const activeElement = e.relatedTarget || document.activeElement;
    if (menuListRef.current && menuListRef.current.contains(activeElement)) {
      return;
    }

    if (open) {
      setAutoFocus(false);
      setOpen(false);
    }
  };

