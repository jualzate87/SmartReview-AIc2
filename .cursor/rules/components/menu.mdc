```typescript
export interface MenuProps extends Themeable {
  /** Key to match string */
  accessStringMatch?: string;
  /**
   * Alignment  to show the Menu, it is a string of alignments
   * vertical: 'top', 'bottom', 'middle'
   * horizontal: 'left', 'right', 'center'
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   *
   * @default 'left'
   */
  alignment?: Alignments;
  /** The element used to set the position of showing the Menu. */
  anchorElement: React.ReactElement;
  /**
   * If the anchor element is a React component, and it needs to an alternative reference, so setting the
   * "anchorElementRefPropName" in order to let popper can forward the ref to call. For example: if anchor
   * element is IDS TextField, then the "anchorElementRefPropName" would be "assignLabelRef" or "assignInputRef"
   * which is a prop function to get the text field DOM reference from the TextField.
   *
   * @default ''
   */
  anchorElementRefPropName?: string;
  /** aria-label */
  'aria-label'?: string;
  /** aria-labelledby */
  'aria-labelledby'?: string;
  /**
   * Determine whether focus on a menu-item when Menu opens
   *
   * @default false
   */
  autoFocus?: boolean;
  /** Menu contents, normally are `MenuItem`s. */
  children?:
    | React.ReactElement<MenuItemProps>
    | React.ReactElement<MenuItemProps>[];
  /** Class to be assigned to Menu. Use to extend the style. */
  className?: string;
  /**
   * Determine whether Menu is disabled
   *
   * @default false
   */
  disabled?: boolean;
  /**
   * Determine whether MenuItem can be searched by typing
   *
   * @default false
   */
  disableSearch?: boolean;
  /** A callback function to get index of current selected item in Menu */
  getSelectedIndex?: (index: number) => void;
  /**
   * Determine whether the MenuItem is highlighted
   *
   * @default -1
   */
  highlightIndex?: number;
  /** ID to be applied to the menu. */
  id?: string;
  /**
   * Array of classnames.
   * If these classnames are clicked, the component is not to call onBlur.
   *
   * @default []
   */
  ignoreIdsOnBlur?: string[];
  /** Determine the maximum width of Menu, unit is px. */
  maxHeight?: string | number;
  /**
   * An ARIA role to be assigned to MenuItem.
   *
   * @default 'menuitem'
   */
  menuItemRole?: string;
  /**
   * An ARIA role to be assigned to Menu.
   *
   * @default 'menu'
   */
  menuRole?: string;
  /** Determine the minimum width of Menu, unit is px. */
  minWidth?: string | number;
  /** Callback fired when the Menu wants to blur */
  onBlur?: (e: React.KeyboardEvent | React.FocusEvent) => void;
  /** Callback fired when the Menu wants to close */
  onClose?: (e: React.KeyboardEvent | React.FocusEvent) => void;
  /** Callback fired when the mouse hover the Menu */
  onMouseEnter?: React.MouseEventHandler;
  /** onSelect callback receive from parent to handle open/close, get selectedItem */
  onSelect?: (
    e: React.MouseEvent<HTMLLIElement> | React.KeyboardEvent<HTMLLIElement>
  ) => void;
  /** Callback fired when the Menu gets clicked away */
  onClickAway?: (e: React.MouseEvent | React.KeyboardEvent) => void;
  /** If `true`, the Menu shows. */
  open: boolean;
  /**
   * menuOffsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  menuOffsetSkidding?: number;
  /**
   * menuOffsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  menuOffsetDistance?: number;
  /**
   * menuOffsetX: the x axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   * @deprecated Please use menuOffsetSkidding instead
   */
  menuOffsetX?: number;
  /**
   * menuOffsetY: the y axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   * @deprecated Please use menuOffsetDistance instead
   */
  menuOffsetY?: number;
  /**
   * Position to show the Menu, value is string of alignments
   * vertical: 'top', 'bottom'
   * horizontal: 'left', 'right'
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   *
   * @default 'bottom'
   */
  position?: Positions;
  /**
   * preventMenuOverflow: an object variable; used to prevent Menu from being positioned outside the boundary.
   * More detail in @ids-ts/position preventOverflow API document.
   */
  preventMenuOverflow?: PreventOverflow;
  /** Callback that returns the ref for menu */
  reference?: (c: HTMLUListElement | null) => void;
  /**
   * This will ensure that the currently highlighted element will scroll
   * into the Menu view to always be visible if necessary
   *
   * @default false
   */
  scrollToSelected?: boolean;
  /**
   * Determine which search type to apply while typing
   * full - search sequentially adding typed symbols from the beginning
   * first - mimic all behavior to match first char only
   * partial - search for the first occurrence in the middle of displayed items
   *
   * @default 'first'
   */
  searchMode?: 'full' | 'first' | 'partial';
  /** This will highlight the selectedItem in Menu */
  selectedItem?: string | number | (string | number)[];
  /**
   * This will show a CheckMark on the current selected item in Menu
   *
   * @default false
   */
  showCheckmark?: boolean;
  /** Affects size of text rendered next to checkbox
   *
   * @default 'medium'
   *
   */
  size?: 'small' | 'medium';
  /** The optional styles applied to the MenuList. */
  style?: React.CSSProperties;
  /** The optional styles applied to the position node wrapped around the root node. */
  stylePosition?: React.CSSProperties;
  /**
   * Dependencies that will cause the popperjs instance to recalculate its position, whenever any of the dependencies change.
   * These dependencies work the same way as the list you would pass into a React useEffect()
   */
  positionDependencies?: unknown[];
}

