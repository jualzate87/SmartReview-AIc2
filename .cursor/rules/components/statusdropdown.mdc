### Playground

```tsx
({ status, label, size }) => {
  const [labelState, setLabelState] = useState('');
  const [statusState, setStatusState] = useState(status);

  useEffect(() => {
    if (status) {
      setStatusState(status);
    }
  }, [status]);

  useEffect(() => {
    if (label) {
      setLabelState(label);
    }
  }, [label]);

  const handleSelect = (event: ReactStatusDropdownEvent) => {
    const { value } = event.target as HTMLInputElement;
    const { label: selectedLabel, status: selectedStatus } = JSON.parse(value);
    setLabelState(selectedLabel);
    setStatusState(selectedStatus);
    action(`firing from onSelect in playground: ${value}`)();
  };

  const options = [
    { label: 'To do', status: Status.toDo },
    { label: 'In progress', status: Status.inProgress },
    { label: 'Waiting', status: Status.waiting },
    { label: 'Blocked', status: Status.error },
    { label: 'Done', status: Status.success },
    { label: 'Overdue', status: Status.warning }
  ];

  const menuItems = getMenuItems(options, 5);

  return (
    <StatusDropdown
      size={size}
      label={labelState || label}
      status={statusState || status}
      onSelect={handleSelect}
    >
      {menuItems}
    </StatusDropdown>
  );
}
```

