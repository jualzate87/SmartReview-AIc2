## Usage Patterns

### Basic Usage

```tsx
() => {
  const [status, setStatus] = useState(Status.toDo);
  const [label, setLabel] = useState('To do');

  useEffect(() => {
    if (status) {
      setStatus(status);
    }
  }, [status]);

  const handleSelect = (event: ReactStatusDropdownEvent) => {
    const { value } = event.target as HTMLInputElement;
    const { label: selectedLabel, status: selectedStatus } = JSON.parse(value);
    setLabel(selectedLabel);
    setStatus(selectedStatus);
    action(`firing from onSelect in playground: ${value}`)();
  };

  const options = [
    { label: 'To do', status: Status.toDo },
    { label: 'In progress', status: Status.inProgress },
    { label: 'Waiting', status: Status.waiting },
    { label: 'Blocked', status: Status.error },
    { label: 'Done', status: Status.success },
    { label: 'Overdue', status: Status.warning }
  ];
  const menuItems = getMenuItems(options, 6);

  return (
    <StatusDropdown label={label} status={status} onSelect={handleSelect}>
      {menuItems}
    </StatusDropdown>
  );
}
```

