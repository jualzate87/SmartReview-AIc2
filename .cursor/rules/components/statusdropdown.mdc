# StatusDropdown

Welcome to my `StatusDropdown` component.

## Installation & Import

```bash
yarn add @ids-ts/status-dropdown
```

```tsx
import { StatusDropdown } from '@ids-ts/status-dropdown';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `children` | `ReactElement<MenuItemProps> \| ReactElement<MenuItemProps>[]` | Yes | MenuItem children for the dropdown. |
| `label` | `string` | Yes | Required label to be placed on the StatusDropdown as the label |
| `status` | `Status` | Yes | Required status to be placed on the StatusDropdown as the status |
| `preventMenuOverflow` | `an object variable` | Yes | - |
| `preventMenuOverflow` | `PreventOverflow` | No | - |
| `onSelect` | `(event: ReactStatusDropdownEvent) => void` | No | Function which will be called when a menu item is selected |
| `menuPositionStyle` | `React.CSSProperties` | No | The optional styles applied to the position node wrapped around the root node. |
| `size` | `'standard' \| 'mini'` | No | Size variant. Defaults to `'standard'`. |
| `warningText` | `string` | No | warning message to be rendered. |
| `validationWarning` | `boolean` | No | validation warning displays only warning styles without text |
| `disabled` | `boolean` | No | whether the component should be disabled or not |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface StatusDropdownProps
  extends Omit<ThemeableElement<'div'>, 'onSelect'> {
  /** Children of Menu or MenuItems */
  children:
    | React.ReactElement<MenuItemProps>
    | React.ReactElement<MenuItemProps>[];
  /** Required label to be placed on the StatusDropdown as the label */
  label: string;
  /** Required status to be placed on the StatusDropdown as the status */
  status: Status;
  /**
   * preventMenuOverflow: an object variable; used to prevent StatusDropdown Menu from being positioned outside the boundary.
   * More detail in @ids-ts/position preventOverflow API document.
   */
  preventMenuOverflow?: PreventOverflow;
  /** Function which will be called when a menu item is selected */
  onSelect?: (event: ReactStatusDropdownEvent) => void;
  /** The optional styles applied to the position node wrapped around the root node. */
  menuPositionStyle?: React.CSSProperties;
  /**
   * variation in size: standard or mini
   *
   * @default 'standard'
   */
  size?: StatusDropdownSize;
  /** warning message to be rendered. */
  warningText?: string;
  /** validation warning displays only warning styles without text */
  validationWarning?: boolean;
  /** whether the component should be disabled or not */
  disabled?: boolean;
}

export enum Status {
  toDo = 'toDo',
  inProgress = 'inProgress',
  waiting = 'waiting',
  error = 'error',
  success = 'success',
  warning = 'warning'
}

export type ReactStatusDropdownEvent = React.KeyboardEvent | React.MouseEvent;

export type StatusDropdownSize = 'mini' | 'standard';
```

</details>

