### Click Event Handler

```tsx
() => {
  // The same or different callbacks could be passed in for each ButtonInterface through the buttonInfos prop.
  const customOnClickCallback: React.EventHandler<React.SyntheticEvent>[] = [
    () => action('click')('Custom onClick for SegmentedButton 1'),
    () => action('click')('Custom onClick for SegmentedButton 2'),
    () => action('click')('Custom onClick for SegmentedButton 3')
  ];

  return (
    <SegmentedButton
      ariaLabel="IDS SegmentedButton onClick example"
      buttonInfos={generateData(3, customOnClickCallback)}
      buttonType="standard"
      id="segmented-button-click-handler"
    />
  );
}
```

### Pre Selected Button

```tsx
() => {
  // Pre selecting the button at index 2
  const boolean = [false, false, true, false];
  // The same callbacks is passed in for each ButtonInterface.
  const selectedOnClick: React.EventHandler<React.SyntheticEvent>[] = [
    () => action('click')('Custom onClick for SegmentedButton 1'),
    () => action('click')('Custom onClick for SegmentedButton 2'),
    () => action('click')('Custom onClick for SegmentedButton 3'),
    () => action('click')('Custom onClick for SegmentedButton 4')
  ];

  return (
    <SegmentedButton
      ariaLabel="segmented button"
      buttonInfos={generateData(4, selectedOnClick, boolean)}
      buttonType="standard"
      id="segmented-button-preselected"
    />
  );
}
```

### Externally Controlled

```tsx
() => {
  const [selectedArray, setSelectedArray] = useState([
    true,
    false,
    false,
    false
  ]);
  const [selectedIndex, setSelectedIndex] = useState(0);
  const colors = ['gray', 'blue', 'green', 'red'];
  const selectRandomTab = () => {
    let randomIndex = Math.floor(Math.random() * selectedArray.length);

    while (randomIndex === selectedIndex) {
      randomIndex = Math.floor(Math.random() * selectedArray.length);
    }

    const newSelectedArray = [...selectedArray];

    newSelectedArray[randomIndex] = true;
    newSelectedArray[selectedIndex] = false;

    setSelectedArray(newSelectedArray);
    setSelectedIndex(randomIndex);
  };

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: '100px' }}>
      <Button onClick={selectRandomTab}>
        Change the tab by not changing the tab!
      </Button>
      <SegmentedButton
        ariaLabel="segmented button"
        buttonInfos={selectedArray.map((selected, index) => ({
          label: buttonNames[index],
          selected,
          content: (
            <ContentExample
              message={faker.lorem.paragraphs(2)}
              color={colors[index]}
            />
          ),
          onClick: () => action('click')(`Segment ${index} clicked`)
        }))}
        buttonType="standard"
        id="segmented-button-externally-controlled"
      />
    </div>
  );
}
```

## Code Example

```tsx
import React from 'react';
import SegmentedButton from '@ids-ts/segmented-button';
// and with css-modules
import '@ids-ts/segmented-button/dist/main.css';

const ContentExample = ({ message }) => {
  const renderStyle = {
    padding: '10px',
    display: 'block',
    width: '1030px'
  };

  return <p style={renderStyle}>{message}</p>;
};

const SegmentedButtonExample = () => (
  <SegmentedButton
    ariaLabel="segmented button"
    buttonPosition="center"
    buttonType="standard"
    buttonInfos={[
      {
        label: 'Segmented 1',
        content: <ContentExample message="Good Morning!" />,
        selected: true,
      },
      {
        label: 'Segmented 2',
        selected: false,
      },
      {
        label: 'Segmented 3',
        content: <ContentExample message="Good Night!" />,
        selected: false,
      }
    ]},
  />
);

export default SegmentedButtonExample;
```

