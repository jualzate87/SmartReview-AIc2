## Usage Patterns

### Basic Usage

```tsx
({ placement, collapsible }) => {
  const panelStateLeft = usePanelContextual(true);
  const panelStateRight = usePanelContextual(true);

  const onCloseLeft = () => {
    panelStateLeft.onClose();
  };

  const onOpenLeft = () => {
    panelStateLeft.onOpen();
  };

  const onCloseRight = () => {
    panelStateRight.onClose();
  };

  const onOpenRight = () => {
    panelStateRight.onOpen();
  };

  const isPanelOpen =
    (placement === Placement.Left && panelStateLeft.showPanel) ||
    (placement === Placement.Right && panelStateRight.showPanel);
  return (
    <div
      className={clsx(styles.galleryContainer, {
        [styles.open]: isPanelOpen,
        [styles.close]: !isPanelOpen
      })}
    >
      {placement === Placement.Left && (
        <PanelContextual
          open
          autoFocus={false}
          showPanel={panelStateLeft.showPanel}
          hasCollapseControl={collapsible}
          placement={Placement.Left}
          onOpen={onOpenLeft}
          onClose={onCloseLeft}
        >
          <PanelHeader title={panelTitle} />
          <PanelContent>
            <CardDummyComponent />
          </PanelContent>
        </PanelContextual>
      )}
      <div className={styles.dummyComponent} />
      {placement === Placement.Right && (
        <PanelContextual
          open
          autoFocus={false}
          showPanel={panelStateRight.showPanel}
          hasCollapseControl={collapsible}
          placement={Placement.Right}
          onOpen={onOpenRight}
          onClose={onCloseRight}
        >
          <PanelHeader title={panelTitle} />
          <PanelContent>
            <CardDummyComponent />
          </PanelContent>
        </PanelContextual>
      )}
    </div>
  );
}
```

