## Code Example

```tsx
import React from 'react';
import PanelContextual, {
  PanelContent,
  PanelHeader,
  Placement
} from '@ids-ts/panel-contextual';

const PanelContextualExample = () => {
  return (
    <PanelContextual open hasCollapseControl placement={Placement.Left}>
      <PanelHeader title="PanelContextual title" />
      <PanelContent>Panel Content</PanelContent>
    </PanelContextual>
  );
};

export default PanelContextualExample;
```

