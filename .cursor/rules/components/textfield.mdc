### With Custom Formatter

```tsx
(props: { theme: ThemeType }) => {
  const { theme } = props;
  const [value, setValue] = useState('');

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    action('should be unformatted value: ')(e.target.value);
    setValue(e.target.value);
  };

  const handleCreditCardFormatter = (newValue: string) => {
    const sanitizedValue = newValue.replace(/\D/g, '');
    const formattedValue = sanitizedValue.replace(/.{4}(?=.)/g, '$&-');
    return formattedValue.substr(0, 19);
  };

  const handleUnFormat = (newValue: string) => {
    return newValue.replace(/\D/g, '');
  };

  return (
    <FormattedField
      theme={theme}
      label="Card Number (with hyphens)"
      placeholder="Enter the card number"
      value={value}
      unformat={handleUnFormat}
      formatter={handleCreditCardFormatter}
      id="textfield-customformatter"
      onChange={handleChange}
    />
  );
}
```

