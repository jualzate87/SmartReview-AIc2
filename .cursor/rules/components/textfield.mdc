### Search Field

```tsx
(props: { theme: ThemeType }) => {
  const { theme } = props;
  const [value, setValue] = useState('keywords');

  const SearchIcon = <Search size="small" />;

  const ClearIconControl = value ? (
    <IconControl aria-label="Clear search" onClick={() => setValue('')}>
      <Close size="small" />
    </IconControl>
  ) : undefined;

  const handleKeyDown = (e: React.KeyboardEvent<HTMLInputElement>) => {
    if (e.key === 'Escape') {
      setValue('');
    }
  };

  return (
    <TextField
      theme={theme}
      label="Search"
      placeholder="Search..."
      value={value}
      addonBefore={SearchIcon}
      addonAfter={ClearIconControl}
      helperText="Search icon is always visible, clear button appears when typing. Press Escape to clear."
      id="textfield-search"
      width="100%"
      onChange={(e) => setValue(e.target.value)}
      onKeyDown={handleKeyDown}
    />
  );
}
```

