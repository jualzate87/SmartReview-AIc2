  const [showGhost, setShowGhost] = useState(true);
  const [searchValue, setSearchValue] = useState('keywords');
  const [searchValueSmall, setSearchValueSmall] = useState('keywords');

  const startWithGhostTxt = (textVal: string, newValue: string) => {
    if (!textVal) {
      return false;
    }

    return textVal.indexOf(newValue) === 0;
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (
      e.key === 'Tab' &&
      value &&
      value !== ghostTxt &&
      startWithGhostTxt(ghostTxt, value)
    ) {
      e.preventDefault();
      setValue(ghostTxt);
    }
  };

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const { value: newValue } = e.target;
    setValue(newValue);
    if (!newValue) {
      setShowGhost(true);
    }
  };

  const handleBlur = () => {
    if (value) {
      setShowGhost(false);
    }
  };

  const ghostText =
    showGhost && startWithGhostTxt(ghostTxt, value) ? ghostTxt : '';

  return (
