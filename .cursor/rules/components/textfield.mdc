### Currency Formatted Field Example

```tsx
(props: { theme: ThemeType }) => {
  const { theme } = props;
  const [value, setValue] = useState('');

  const handleCurrencyFormatter = (newValue: string) => {
    let sanitizedValue = newValue.replace(/[^0-9.]/g, '');
    sanitizedValue = sanitizedValue
      .split('.')
      .map((part, index) =>
        index === 0 ? part.replace(/\B(?=(\d{3})+(?!\d))/g, ',') : part
      )
      .join('.');
    const decimalIndex = sanitizedValue.indexOf('.');
    if (decimalIndex !== -1) {
      sanitizedValue = sanitizedValue.slice(0, decimalIndex + 3);
    }

    return `$${sanitizedValue}`; // Added $ in the returned value
  };

  const handleUnFormat = (newValue: string) => {
    return newValue.replace(/[^0-9.]/g, '');
  };

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const newValue = handleUnFormat(e.target.value);
    setValue(handleCurrencyFormatter(newValue));
  };

  const handleCurrencyCursorPosition = (
    prevVal: string,
    nextVal: string,
    selectionStart: number | null,
    digitEntered?: boolean
  ) => {
    // eslint-disable-next-line no-param-reassign
    selectionStart = selectionStart || 1;

    // this is executed when a comma is added due to number formatting
    if (nextVal.length - prevVal.length > 1 && digitEntered) {
      return selectionStart + 1;
    }

    return selectionStart;
  };

  return (
    <FormattedField
      theme={theme}
      label="Currency"
      placeholder="Enter currency"
      value={value}
      id="textfield-currency"
      unformat={handleUnFormat}
      formatter={handleCurrencyFormatter}
      cursorPositionHandler={handleCurrencyCursorPosition}
      onChange={handleChange}
    />
  );
}
```

