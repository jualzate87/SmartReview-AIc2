### With On Change

```tsx
(props: { theme: ThemeType }) => {
  const { theme } = props;
  const [value, setValue] = useState('');
  const [errorText, setErrorText] = useState('');
  const [warningText, setWarningText] = useState('');

  return (
    <TextField
      theme={theme}
      label="Name"
      placeholder="Jane Doe"
      errorText={errorText}
      warningText={warningText}
      value={value}
      helperText="onChange adds a warning at 4 characters and error at 8 characters"
      onChange={(e) => {
        const { value: newValue } = e.target;
        const newWarningText =
          newValue.length >= 5 && newValue.length < 8
            ? 'Warning!! Entered 5 chars'
            : '';
        const newErrorText =
          newValue.length >= 8 ? 'Error!! Entered 8 chars' : '';

        setValue(newValue);
        setErrorText(newErrorText);
        setWarningText(newWarningText);
      }}
    />
  );
}
```

### With Ghost Text

```tsx
(props: { theme: ThemeType }) => {
  const { theme } = props;
  const [value, setValue] = useState('');
  const [showGhost, setShowGhost] = useState(true);
  const ghostTxt = 'Jane Doe';

  const startWithGhostTxt = (text: string, newValue: string) => {
    if (!text) {
      return false;
    }

    return text.indexOf(newValue) === 0;
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (
      e.key === 'Tab' &&
      value &&
      value !== ghostTxt &&
      startWithGhostTxt(ghostTxt, value)
    ) {
      e.preventDefault();
      setValue(ghostTxt);
    }
  };

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const { value: newValue } = e.target;
    setValue(newValue);
    if (!newValue) {
      setShowGhost(true);
    }
  };

  const handleBlur = () => {
    if (value) {
      setShowGhost(false);
    }
  };

  const ghostText =
    showGhost && startWithGhostTxt(ghostTxt, value) ? ghostTxt : '';

  return (
    <>
      <TextField
        theme={theme}
        label="First Name"
        ghostText={ghostText}
        helperText="A ghost text is like placeholder, but can be controllable."
        value={value}
        onBlur={handleBlur}
        onChange={handleChange}
        onKeyDown={handleKeyDown}
      />
      <TextField
        theme={theme}
        label="First Name"
        ghostText={ghostText}
        helperText="Here it is with an addonBefore"
        addonBefore={<Search size="medium" color="#6B6C72" />}
        value={value}
        onBlur={handleBlur}
        onChange={handleChange}
        onKeyDown={handleKeyDown}
      />
    </>
  );
}
```

