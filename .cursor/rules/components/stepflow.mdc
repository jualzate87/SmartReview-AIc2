## Usage Patterns

### Basic Usage

```tsx
() => {
  return (
    <Trowser
      open
      stepFlow
      hideOverflow
      dismissible
      title="Payroll Setup"
      headerClassName={trowserHeaderWithStepFlow}
    >
      <StepFlow className={styles.flow}>
        <Step title="Welcome" hasPreviousButton={false} />
        <Step title="Enter your business name" />
        <Step title="Enter your business address" />
        <Step
          title="Congratulations"
          subtitle={confirmationPageSubTitle}
          nextButtonText="Done"
          type="confirmation"
          hasPreviousButton={false}
        />
      </StepFlow>
    </Trowser>
  );
}
```

