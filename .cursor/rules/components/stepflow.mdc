### With Skipped Step

```tsx
() => {
  const [isSkipped, setIsSkipped] = useState(false);
  const stepFlowState = useStepFlow();

  function skipHandler() {
    setIsSkipped(true);
    stepFlowState.goToNext();
  }

  function nextHandler() {
    setIsSkipped(false);
    stepFlowState.goToNext();
  }

  return (
    <Trowser
      open
      stepFlow
      hideOverflow
      dismissible
      title="Payroll Setup"
      headerClassName={trowserHeaderWithStepFlow}
    >
      <StepFlow
        {...stepFlowState}
        className={styles.flow}
        progressType="indicator"
      >
        <Step
          hasSkipButton
          isSkipped={isSkipped}
          hasPreviousButton={false}
          label="Welcome"
          title="Welcome"
          subtitle="This step is skippable, try hitting Skip."
          onNext={() => nextHandler()}
          onSkip={() => skipHandler()}
        />
        <Step title="Enter your business name" label="Business name" />
        <Step title="Enter your business address" label="Business address" />
        <Step
          title="Congratulations"
          subtitle={confirmationPageSubTitle}
          type="confirmation"
          nextButtonText="Done"
          hasPreviousButton={false}
        />
      </StepFlow>
    </Trowser>
  );
}
```

