## Usage Patterns

### Dark Background

```tsx
() => {
  const [open, setOpen] = useState(false);
  const openBackdrop = () => {
    setOpen(true);
    setTimeout(() => setOpen(false), 2000);
  };

  return (
    <div style={{ display: 'flex', flexDirection: 'column' }}>
      <Button onClick={openBackdrop}>Click Me</Button>
      <Backdrop open={open} zIndex={1} />
      <div>
        <span>The backdrop will be active for 2 seconds</span>
      </div>
    </div>
  );
}
```

### Light Background

```tsx
() => {
  const [open, setOpen] = useState(false);
  const openBackdrop = () => {
    setOpen(true);
    setTimeout(() => setOpen(false), 2000);
  };

  return (
    <div style={{ display: 'flex', flexDirection: 'column' }}>
      <Button onClick={openBackdrop}>Click Me</Button>
      <Backdrop light open={open} zIndex={1} />
      <div>
        <span>The backdrop will be active for 2 seconds</span>
      </div>
    </div>
  );
}
```

