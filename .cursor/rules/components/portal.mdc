## Usage Patterns

### Showcase

```tsx
() => {
  const [open, setOpen] = useState(false);

  return (
    <div>
      <Button data-automation-id="basicButton" onClick={() => setOpen(!open)}>
        Toggle Portal
      </Button>

      {open && (
        <>
          <p style={{ marginTop: 40 }}>
            Portal is rendered at the end of the document.body.
          </p>
          <Portal>
            This is a Portal, rendered at the end of the document.body!
          </Portal>
        </>
      )}
    </div>
  );
}
```

### Portal Inside Iframe

```tsx
() => {
  const [iframeLoaded, setIframeLoaded] = useState(false);
  const iframeRef = React.useRef<HTMLIFrameElement>(null);
  return (
    <iframe
      ref={iframeRef}
      title="testPortalIframe"
      onLoad={() => setIframeLoaded(true)}
    >
      {iframeLoaded && iframeRef.current && (
        <Portal ownerDocument={iframeRef.current.contentDocument}>
          Portal Inside iframe
        </Portal>
      )}
    </iframe>
  );
}
```

### Multiple Portals

```tsx
() => {
  const [removedSecond, setRemovedSecond] = React.useState<boolean>(false);
  useEffect(() => {
    if (!removedSecond) {
      setRemovedSecond(true);
    }
  }, [removedSecond]);
  return (
    <div>
      <p>Portals are rendered at the end of the document.body.</p>
      <Portal>1</Portal>
      {!removedSecond && <Portal>2</Portal>}
      <Portal>3</Portal>
      {removedSecond && <Portal>4</Portal>}
    </div>
  );
}
```

