## Usage Patterns

### Basic Usage

```tsx
() => {
  return (
    <TooltipContainer>
      <Tooltip
        automationId="tooltip_custom"
        message={
          <div>
            <span>This is a default example.</span>
          </div>
        }
      >
        <B2 role="button" id="basic" tabIndex={0}>
          Hover/Focus me
        </B2>
      </Tooltip>
    </TooltipContainer>
  );
}
```

### Basic Usage With Icon

```tsx
() => {
  return (
    <TooltipContainer>
      <Tooltip
        automationId="tooltip_custom"
        message={
          <div>
            <span>This is a default example using tooltip with an icon.</span>
          </div>
        }
      >
        <IconControl aria-label="Hover/Focus Me" size="small">
          <CircleInfo size="small" />
        </IconControl>
      </Tooltip>
    </TooltipContainer>
  );
}
```

### Controlled Click Example With Icon

```tsx
() => {
  const [showTooltip, setShowTooltip] = useState(false);

  const handleClick = () => setShowTooltip(true);
  const handleClose = () => setShowTooltip(false);

  return (
    <TooltipContainer>
      <Tooltip
        dismissible
        disableHoverListener
        open={showTooltip}
        message={
          <div>
            <span>This is a controlled click example.</span>
          </div>
        }
        position="bottom"
        alignment="right"
        onClose={handleClose}
      >
        <CircleInfo
          size="medium"
          aria-label="alert"
          onClick={handleClick}
          onFocus={handleClick}
        />
      </Tooltip>
    </TooltipContainer>
  );
}
```

