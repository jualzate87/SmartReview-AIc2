### Lazy Render Controlled Target

```tsx
() => {
  const [openTooltip, setOpenTooltip] = useState(false);
  const [showTextField, setShowTextField] = useState(false);

  const handler = (e: React.ChangeEvent | React.FocusEvent) => {
    const val = (e.target as HTMLInputElement).value;
    setOpenTooltip(!val);
  };

  useEffect(() => {
    setTimeout(() => {
      setOpenTooltip(false);
    }, 4000);
  }, [openTooltip]);

  return (
    <div>
      <Checkbox
        description="Render lazy loaded Text Field"
        name="fruitLabel"
        size="medium"
        onChange={(e: CheckboxOnChangeEventType) =>
          setShowTextField(e.target.checked ?? false)
        }
      >
        View Target
      </Checkbox>
      <Tooltip
        open={openTooltip}
        automationId="test"
        message="no value set"
        position="right"
      >
        {showTextField && <LazyLoadTextField handler={handler} />}
      </Tooltip>
    </div>
  );
}
```

