() => {
  const {
    headerGroups,
    rows,
    prepareRow,
    getTableProps,
    getTableBodyProps,
    getToggleAllRowsSelectedProps
  } = useTable(
    {
      columns,
      data
    },
    useRowSelect
  ) as TableInstanceWithRowSelect<DataItem>;

  return (
    <Table
      divider="horizontal"
      responsive="elevate"
      {...getTableProps()}
      summary="contributors to the consumer group design systems table component"
    >
      <Table.Header>
        {headerGroups.map((headerGroup) => (
          // eslint-disable-next-line react/jsx-key
          <Table.Row {...headerGroup.getHeaderGroupProps()}>
            <Table.Cell style={{ width: '5px' }} aria-label="Select content">
              <Checkbox
                {...getToggleAllRowsSelectedProps()}
                className={styles.customMarginCheckbox}
                aria-label="Select all rows"
              />
            </Table.Cell>
            {headerGroup.headers.map((column) => (
              // eslint-disable-next-line react/jsx-key
              <Table.Cell {...column.getHeaderProps()}>
                {/*
                  WORKAROUND: The version of @types/react used by react-table might conflict
                  with the main project version, causing a type mismatch on ReactNode.
                  Casting to `any` bypasses this check without changing runtime behavior.
                  This should be removed once dependency versions are aligned.
                */}
                <span>{column.render('Header') as any}</span>
              </Table.Cell>
            ))}
          </Table.Row>
        ))}
      </Table.Header>
      <Table.Body {...getTableBodyProps()}>
        {rows.map((row, i) => {
          const typedRow = row as RowWithRowSelect<DataItem>;

          prepareRow(typedRow);
          return (
            // eslint-disable-next-line react/jsx-key
            <Table.Row {...row.getRowProps()}>
              <Table.Cell style={{ width: '5px' }}>
                <Checkbox
                  {...typedRow.getToggleRowSelectedProps()}
                  aria-label={`choice-example-${i}`}
                />
              </Table.Cell>
              {row.cells.map((cell) => {
                return (
                  // eslint-disable-next-line react/jsx-key
                  <Table.Cell {...cell.getCellProps()}>{cell.value}</Table.Cell>
                );
              })}
            </Table.Row>
          );
        })}
      </Table.Body>
    </Table>
  );
}
