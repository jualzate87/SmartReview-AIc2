() => {
  const DEFAULT_PAGE_SIZE = 10;
  const [page, setPage] = useState(1);
  const tableRef = useRef<HTMLTableRowElement | null>(null); // Ref to the first table row
  const [firstRender, setFirstRender] = useState(true);

  const handlePageChange = (newPage: number) => {
    setPage(newPage);
  };

  // Runs only on the first render
  useEffect(() => {
    setFirstRender(false);
  }, []);

  // Runs after a new page is rendered for the first time,
  // and focuses on the first row of the table when pagination is clicked

  useEffect(() => {
    if (tableRef.current && !firstRender) {
      tableRef.current.focus();
    }
  }, [page]);

  const items = data.slice(
    (page - 1) * DEFAULT_PAGE_SIZE,
    (page - 1) * DEFAULT_PAGE_SIZE + DEFAULT_PAGE_SIZE
  );

  return (
    <Table
      striped
