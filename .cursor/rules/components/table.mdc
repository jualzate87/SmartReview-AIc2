() => {
  const [tableData, setTableData] = useState<DataItem[]>([]);

  useEffect(() => {
    let timeoutId: number | undefined;

    const fetchData = async () => {
      setTableData([]);

      const newData: DataItem[] = await new Promise((resolve) => {
        timeoutId = window.setTimeout(() => {
          resolve(data);
        }, 4500);
      });
      setTableData(newData);
    };

    fetchData();

    return () => {
      window.clearTimeout(timeoutId);
    };
  }, []);

  return (
    <Table
      tabIndex={0}
      summary="contributors to the consumer group design systems table component"
    >
      <Table.Header
        className={clsx(styles.header, styles.sticky)}
        divider="horizontal"
      >
        <Table.Row>
          <Table.Cell className={clsx(styles.header, styles.sticky)}>
            First name
          </Table.Cell>
          <Table.Cell className={clsx(styles.header, styles.sticky)}>
            Last name
          </Table.Cell>
          <Table.Cell className={clsx(styles.header, styles.sticky)}>
            City
          </Table.Cell>
          <Table.Cell className={clsx(styles.header, styles.sticky)}>
            State
          </Table.Cell>
        </Table.Row>
      </Table.Header>
      <Table.Body className={styles.body}>
        {tableData.length === 0 && <Activity shape="dots" />}
        {tableData.length > 0 &&
          tableData.map((item, index) => {
            const id = `row-${index}`;
            return (
              <Table.Row key={id}>
                <Table.Cell>{item.firstName}</Table.Cell>
                <Table.Cell>{item.lastName}</Table.Cell>
                <Table.Cell>{item.city}</Table.Cell>
                <Table.Cell>{item.state}</Table.Cell>
              </Table.Row>
            );
          })}
      </Table.Body>
    </Table>
  );
}
```

