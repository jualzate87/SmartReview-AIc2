## Code Example

```tsx
import React from 'react';
import Button from '@ids-ts/button';
import ToastMessage from '@ids-ts/toast-message';

const ToastMessageExample = () => {
  const [showToast, setShowToast] = React.useState(false);
  const handleActionClick = () => {
    setShowToast(false);
  };

  const handleClick = () => setShowToast(true);
  const handleClose = () => setShowToast(false);

  return (
    <div>
      <Button onClick={handleClick}>Show Toast (Indefinite)</Button>
      <ToastMessage
        dismissible
        showIcon
        open={showToast}
        duration={0}
        actionLabel="Close"
        onClose={handleClose}
        onActionClick={handleActionClick}
      >
        Your invoice has been scheduled.
      </ToastMessage>
    </div>
  );
};

export default ToastMessageExample;
```

