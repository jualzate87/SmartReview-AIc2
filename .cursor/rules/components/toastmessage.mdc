## Usage Patterns

### Basic Example

```tsx
() => {
  const [showToast, setShowToast] = useState(false);

  const handleActionClick = () => {
    action('User can add extra functionality here for action label')();
    setShowToast(false);
  };

  const handleClick = () => setShowToast(true);
  const handleClose = () => setShowToast(false);

  return (
    <div>
      <Button
        id="example_three"
        data-automation-id="basicIndefinite"
        onClick={handleClick}
      >
        Show Toast (Indefinite)
      </Button>
      <ToastMessage
        dismissible
        showIcon
        data-automation-id="indefinite"
        actionLabel=""
        open={showToast}
        duration={0}
        onClose={handleClose}
        onActionClick={handleActionClick}
      >
        <Demi>Title </Demi> this is a basic toast message
      </ToastMessage>
    </div>
  );
}
```

