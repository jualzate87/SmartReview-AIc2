## Usage Patterns

### Position Element Inside Iframe

```tsx
() => {
  const [iframeLoaded, setIframeLoaded] = useState(false);
  const iframeRef = React.useRef<HTMLIFrameElement>(null);
  return (
    <iframe
      ref={iframeRef}
      title="testPortalIframe"
      onLoad={() => setIframeLoaded(true)}
    >
      {iframeLoaded && iframeRef.current && (
        <Portal ownerDocument={iframeRef.current.contentDocument}>
          <Showcase />
        </Portal>
      )}
    </iframe>
  );
}
```

### Showcase

```tsx
() => {
  const [show, setShow] = useState(false);
  const [target, setTarget] = useState<HTMLElement>();
  const buttonRef = React.createRef<HTMLButtonElement>();
  const handleClick = (ref: React.RefObject<HTMLButtonElement>) => {
    // eslint-disable-next-line react/no-find-dom-node
    const newTarget = ReactDOM.findDOMNode(ref.current);
    setTarget(newTarget as HTMLElement);
    setShow(!show);
  };

  return (
    <>
      <Button
        innerRef={buttonRef}
        type="button"
        style={buttonStyle}
        onClick={() => handleClick(buttonRef)}
      >
        With Offset!
      </Button>

      <Position
        componentName="TestPosition"
        targetElement={target as Element}
        offsetSkidding={175}
        offsetDistance={50}
        show={show}
      >
        <div style={childStyle}>
          I have a 175 pixel cross-axis skidding and 50 pixel main-axis
          distance!
        </div>
      </Position>
    </>
  );
}
```

