### With Required

```tsx
() => {
  const [value, setValue] = useState('');
  const [errorText, setErrorText] = useState('');

  return (
    <>
      <TextArea
        required
        label="Shipping address (required)"
        helperText="Add required=true for screen readers"
        value={value}
        errorText={errorText}
        automationId="idsTextAreaRequired"
        onChange={(e: any) => {
          const { value: newValue } = e.target;
          setValue(newValue);
          if (newValue.trim()) {
            setErrorText('');
          }
        }}
        onBlur={(e: any) => {
          const newValue = e.target.value.trim();
          const newErrorText = newValue ? '' : 'Field is required.';
          setErrorText(newErrorText);
        }}
      />
      <p>
        When a semantic HTML <code>&lt;input&gt;</code>,{' '}
        <code>&lt;select&gt;</code>, or <code>&lt;textarea&gt;</code> must have
        a value, it should have the <code>required</code> attribute applied to
        it. The HTML <code>required</code> attribute disables submitting the
        form unless the required form controls have valid values, while ensuring
        those navigating with the aid of assistive technologies understand which
        semantic form controls need valid content.
        <br />
        When form controls are created using non-semantic elements, such as a{' '}
        <code>&lt;div&gt;</code> with a role of <code>checkbox</code>, the{' '}
        <code>aria-required</code> attribute should be included, with a value of{' '}
        <code>true</code>, to indicate to assistive technologies that user input
        is required on the element for the form to be submittable. The{' '}
        <code>aria-required</code> attribute can be used with HTML form
        elements; it is not limited to elements that have an ARIA role assigned.
      </p>
    </>
  );
}
```

### With On Change Example

```tsx
() => {
  const [value, setValue] = useState('');
  const [errorText, setErrorText] = useState('');
  const [warningText, setWarningText] = useState('');

  return (
    <TextArea
      label="onChange adds a warning at 4 characters and error at 8 characters"
      placeholder="Warning and error example"
      errorText={errorText}
      warningText={warningText}
      helperText="Optional helper text"
      value={value}
      onChange={(e: any) => {
        const { value: newValue } = e.target;
        const newWarningText =
          newValue.length >= 5 && newValue.length < 8
            ? 'Warning!! Entered 5 chars'
            : '';
        const newErrorText =
          newValue.length >= 8 ? 'Error!! Entered 8 chars' : '';

        setValue(newValue);
        setErrorText(newErrorText);
        setWarningText(newWarningText);
      }}
    />
  );
}
```

