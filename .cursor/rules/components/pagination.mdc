## Usage Patterns

### Basic

```tsx
() => {
  const [activePage, setActivePage] = useState(4);
  const totalItems = 700;

  return (
    <div>
      <Pagination
        totalPages={14}
        pageSize={50}
        totalItems={totalItems}
        activePage={activePage}
        labels={{
          page: 'Page',
          of: 'of',
          summaryItems: 'items',
          previousPageButtonAriaLabel: 'Go to previous page, currently on page',
          nextPageButtonAriaLabel: 'Go to next page, currently on page',
          goToPageButtonAriaLabel: 'Go to page',
          pageNumberTextFieldAriaLabel: 'Page number'
        }}
        onPageChange={(page) => {
          setActivePage(page);
        }}
      />
    </div>
  );
}
```

### Custom Summary Section

```tsx
() => {
  const settings = {
    totalItems: 700,
    pageSize: 50,
    totalPages: 14,
    activePage: 4,
    labels: {
      fullSummaryContent: '151 - 200 of 700 accounts'
    }
  };

  return (
    <div>
      <Pagination {...settings} onPageChange={(page) => page} />
    </div>
  );
}
```

### Async Loading Transition

```tsx
() => {
  const [activePage, setActivePage] = useState(1);
  const [isLoadingTotals, setIsLoadingTotals] = useState(true);
  const totalItems = 250;

  // Simulate async data loading - after 5 seconds, show loaded state
  useEffect(() => {
    const timer = setTimeout(() => {
      setIsLoadingTotals(false);
    }, 5000);

    return () => clearTimeout(timer);
  }, []); // Empty dependency array to run only once on mount

  const handlePageChange = (page: number) => {
    setActivePage(page);
  };

  // Create loading component using Activity from @ids-ts/loader for a11y compliance
  const loadingComponent = (
    <Activity shape="dots" size="small" aria-label="Loading data" />
  );

  return (
    <div>
      <h3>Async Loading Transition</h3>
      <p>
        Demonstrates practical usage: starts with loading state, then
        transitions to loaded state after 5 seconds.
      </p>
      <Pagination
        totalPages={10}
        pageSize={25}
        totalItems={totalItems}
        activePage={activePage}
        isLoadingTotals={isLoadingTotals}
        loadingComponent={loadingComponent}
        labels={{
          page: 'Page',
          of: 'of',
          summaryItems: 'items',
          previousPageButtonAriaLabel: 'Go to previous page, currently on page',
          nextPageButtonAriaLabel: 'Go to next page, currently on page',
          goToPageButtonAriaLabel: 'Go to page',
          pageNumberTextFieldAriaLabel: 'Page number'
        }}
        onPageChange={handlePageChange}
      />
      <div style={{ marginTop: '16px', fontSize: '14px', color: '#666' }}>
        Status: {isLoadingTotals ? 'Loading...' : 'Loaded'}
      </div>
    </div>
  );
}
```

