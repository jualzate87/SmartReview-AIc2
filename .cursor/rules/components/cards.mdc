### Progress Indicator

```tsx
() => {
  const cardStyle = { margin: 25 };

  return (
    <div style={{ display: 'flex', boxSizing: 'border-box' }}>
      <Card
        size="small"
        style={cardStyle}
        onClick={action('Progress bar indicator (card 1) clicked')}
      >
        <CardContent>
          This is the first card with uncompleted tasks.
        </CardContent>
        <CardProgressBarIndicator
          ofLabel="sur"
          position={1}
          total={2}
          aria-label="First Card Progress Bar"
        />
      </Card>
      <br />
      <Card
        size="small"
        style={cardStyle}
        onClick={action('Progress bar indicator (card 2) clicked')}
      >
        <CardContent>
          This is the second card with all completed tasks.
          <br />
          This card is using the QuickBooks theme.
        </CardContent>
        <CardProgressBarIndicator
          theme="quickbooks"
          position={2}
          total={2}
          aria-label="Second Card Progress Bar"
        />
      </Card>
    </div>
  );
}
```

