   * This is used as a prop by both datePropParser and the component that gets generated from it.
   * datePropParser only takes a string, and its child component only takes a DateWrapper object.
   * The string "endingDate" is hardcoded in datePropUtils
   */
  endingDate?: string | DateWrapper;
  /** Id of the root container */
  id?: string;
  /** See TextField.errorText */
  errorText?: string;
  /** This is set automatically by datePropUtils, but it can be overridden for testing purposes if desired. */
  isMobile?: boolean;
  /** Used by DateRangePicker for styling reasons. */
  isRangePicker?: boolean;
  /** Used by isMonthYearPicker for styling reasons. */
  isMonthYearPicker?: boolean;
  /** See TextField.label */
  label?: string;
  /**
   *  The current locale in the user's browser. If not supplied, DatePropParser defaults this to
   *  navigator.userLanguage || navigator.language || 'en' . Since that is not an optimal way to
   *  get the locale, it's recommended that plugins override this setting. This setting controls
