  onFocus?: React.FocusEventHandler;
  /** See TextField.props.onBlur */
  onBlur?: React.FocusEventHandler;
  /** See TextField.props.onChange */
  onChange?: (event: ChangeEventType) => void;
  /**
   * Fires when the calendar is display to the user.
   * Not supported on mobile devices -- try listening to the focus event on TextField instead
   * On the desktop, the calendar is shown when the TextField is focused, unless the user has
   * just submitted a valid input.
   */
  onCalendarOpen?: () => void;
  /**
   * Fires when the calendar stops being displayed.
   * Not supported on mobile devices -- try listening to the blur event on the TextField instead.
   * For the desktop, the calendar is always closed when TextField is not being focused.
   */
  onCalendarClose?: () => void;
  /**
   * Custom aria-label for previous month.
   * Used for accessibility purpose when one hovers over previous month button
   *
   * @default 'Go to previous month'
   */
  previousMonthAriaLabel: string;
  /**  See TextField.props.placeholder */
  placeholder?: string;
  /**
   * preventCalendarOverflow: an object variable; used to prevent calendar from being positioned outside the boundary.
   * More detail in @ids-ts/position preventOverflow API document.
   */
  preventCalendarOverflow?: PreventOverflow;
  /**
   * Function to render tooltips for special dates.
   * Make sure to pass 'tooltips' prop.
   * Params (abbreviatedDateFormat, tooltipText, renderDay, restProps) gets resolved internally.
   * where 'abbreviatedDateFormat' is of type String and gets resolved from date provided in 'tooltips' prop.
   *       'tooltipText' refers to message passed against date in 'tooltips' prop.
   *       'renderDay' is internal function that renders day with tooltip.
   *       'restProps' helps in styling tooltip.
   */
  renderTooltip?: RenderTooltipType;
  /**
   * This prop is not implemented by DatePicker code, it is for work-around purpose.
   * False does nothing. Set to true to focus the TextField input box, thus showing the calendar.
   * Please note that this prop does not work on the initial render.
   * However, if always set to true, this will automatically focus the TextField box every time
   * the DatePicker is re-rendered, which is probably not desirable. One way to avoid this
   * problem is to not keep the "showCalendar" value in your React state (of whatever component
   * is using the DatePicker); rather, after setting it to true once, manually set it to false
   * after the next render. Another work-around is to call showCalendar on the
   * DatePickerComponent (Use the internalRef prop to get a reference to DatePickerComponent).
   * Not supported on mobile since the calendar is not rendered on mobile devices.
   */
  showCalendar?: boolean;
  /** Size of the datepicker to render. Affects only the text field */
  size?: TextFieldProps['size'];
  /**
   * This prop is used by DateRangePicker to show date ranges and decide which dates are selectable.
   * This is used as a prop by both DatePropParser and the component that gets generated from it.
   * DatePropParser only takes a string, and its child component only takes a DateWrapper object.
   * The string "startingDate" is hardcoded in datePropUtils.
   */
  startingDate?: string | DateWrapper;
  /**
   * The optional styles applied to the calendar position node to additionally style the calendar popover.
   */
  calendarPositionStyle?: React.CSSProperties;
  /** className from styles based of theme and colorScheme */
  themeClass?: string;
  /**
   * An object that maps dates to tooltips to display on those date cells.
   * Keys should be in short ISO format. For example:
   * {'2017-06-06': 'Salute', '2017-10-06': 'It is a fun day today.'}
   * Not supported on mobile.
   * Always use this prop with renderTooltip prop
   *
   * @default {}
   */
  tooltips: Record<string, string>;
  /**
   * Will render a TextField with the style of a warning without the need for error text or warning text
   * It is a boolean property passed onto TextField,
   *
   * @default false
   */
  validationError?: boolean;
  /** Used to set the textFieldWidth
   * you can pass a number or string with digits and (percentage or other unit like px)
   * if no width is passed then 185px will be the default width
   * ex: width={300}
   * ex: width="200px"
   * ex: width="350"
   * ex: width="100%"
   * ex: width="75%"
   */
  width?: number | string;
  /** Warning message to be rendered. It is passed on to TextField */
  warningText?: string;
  /**
   * Setting this value to true results in two months being displayed at the same time. This is
   * primarily for use by the HADateRangePicker but can be used for a single HADatePicker as well.
   * Not supported on mobile.
   */
  useDoubleCalendar?: boolean;
  /**
   * Date used to set the value in the TextField input box.
   *
   * @default ''
   */
  value: string | DateWrapper;

  /** Flag to display strikes on any dates that fall outside of the min/max range. */
  displayStrikeOutsideOfMinMaxRange?: boolean;
  /** Setting this value to true enables month and year quickselect */
  enableMonthYearQuickSelect?: boolean;
  /** The minimum year to start with for the quickselect dropdown menu in MonthHeader  */
  quickSelectMinYear?: number;
  /** The maximum year to start with for the quickselect dropdown menu in MonthHeader  */
  quickSelectMaxYear?: number;
}

