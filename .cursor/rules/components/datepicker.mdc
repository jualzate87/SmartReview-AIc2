  /**
   * This is used as a prop by both datePropParser and the component that gets generated from it.
   * datePropParser only takes a string, and its child component only takes a DateWrapper object.
   * The same is true for maxDate, minDate, startingDate, and value.
   * currentDate: The date DatePicker will assume is today. Defaults to today if undefined.
   * This is primarily useful in writing tests and gallery examples.
   * The string "currentDate" is hardcoded in datePropUtils
   *
   * @default DateWrapper.getCurrentDate('en')
   */
  currentDate: string | DateWrapper;
  /**
   * This prop would trigger the browser tool tip, used for accessibility purpose. Defaulted to 'Current Date'
   *
   * @default 'Current Date'
   */
