   * DatePropParser should only take a string, and its child component should only take a DateWrapper object.
   * The string "maxDate" is hardcoded in datePropUtils.
   */
  maxDate?: string | DateWrapper;
  /**
   *  A date in short ISO format indicating the earliest date, inclusive, for which this component
   *  is valid. On a desktop, setting this value will prevent the DatePicker's calendar from
   *  navigating to any dates prior to it.
   * This is used as a prop by both datePropParser and the component that gets generated from it.
   * DatePropParser should only take a string, and its child component should only take a DateWrapper object.
   * The string "minDate" is hardcoded in datePropUtils.
   */
  minDate?: string | DateWrapper;
  /**
   * The names of the months to display in the calendar. DatePropParser
   * sets this based on the locale. Not supported on mobile.
   *
   * @default ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
   */
  monthLabels: string[];
  /** See TextField.props.name */
  name?: string;
  /**
   * Custom aria-label for next month navigation.
   * Used for accessibility purpose when one navigates over next month button
   *
   * @default 'Go to next month'
   */
  nextMonthAriaLabel: string;
