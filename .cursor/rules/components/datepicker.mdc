  /** Index string to be used in terms of date range picker calendar for styling: 'start' or 'end'.  */
  'data-drpIndex'?: DrpIndexType;
  /** Used to announce min date via screen reader for accessibility purpose */
  announcementMinDate?: string;
  /** Used to announce max date via screen reader for accessibility purpose */
  announcementMaxDate?: string;
  /**
   * Used to announce current date via screen reader for accessibility purpose
   *
   * @default 'This is the current date'
   */
  announcementCurrentDate: string;
  /**
   * An array of un-select-able dates in short ISO format that cannot be selected by the user.
   * Example: ['2018-06-07', '2018-07-07', '2018-08-07', '2018-09-07', '2018-10-07', ].
   * On a mobile device, the user will still be able to select these dates, but the input box
   * will be marked as invalid and an error message will display, similar to what happens on a
   * desktop when a user types in a blackout date.
   *
   * @default []
   */
