### Reset

```tsx
() => {
  const [value, setValue] = useState('07/15/2020');
  const [shouldFocus, setShouldFocus] = useState(false);
  const resetDate = '01/01/2020';
  const datePickerRef = useRef<any>(null);

  const handleInputChange = (event: ChangeEventType) => {
    const { value: newValue } = event.target as HTMLInputElement;
    setValue(newValue);
  };

  const reset = () => {
    setValue('01/01/2020');
    setShouldFocus(true);
  };

  const handleBlur = (event: FocusEvent) => {
    const targetElement = event.target as HTMLInputElement;
    const newValue = targetElement.value.trim();
    setValue(newValue);
  };

  const handleInternalRef = (ref: any) => {
    datePickerRef.current = ref;
  };

  // Focus the DatePicker input after reset so screen reader can announce the new date
  useEffect(() => {
    if (!shouldFocus) {
      return;
    }

    datePickerRef.current?.textFieldInputRef?.focus();
    setShouldFocus(false);
  }, [shouldFocus]);

  return (
    <div>
      <B2>
        <p>Reset date: {resetDate}</p>
      </B2>
      <div style={{ display: 'flex' }}>
        <DatePicker
          internalRef={handleInternalRef}
          aria-label="Shipping Date"
          value={value}
          data-automation="reset"
          onChange={handleInputChange}
          onBlur={handleBlur}
        />
        <div style={{ marginLeft: '10px' }}>
          <Button onClick={reset}>Reset Date</Button>
        </div>
      </div>
    </div>
  );
}
