### With Auto Formatting

```tsx
({
  locale,
  dateFormat
}: Record<string, string>) => {
  // changing locale does nothing for auto format
  // but I will provide it for those who are curious
  const [value, setValue] = useState('');
  const [errorText, setErrorText] = useState('');

  const validateInput = (rawInput: string) => {
    const sanitizeInput = moment(rawInput, dateFormat, true);
    if (!sanitizeInput.isValid()) {
      return false;
    }

    const instance = moment(sanitizeInput, dateFormat, true);
    const selectedDate = instance.locale(locale);
    if (!selectedDate) {
      action('Invalid argument passed to DatePickerComponent.validateInput:')(
        selectedDate
      );
      return false;
    }

    setErrorText('');
    return true;
  };

  const handleInputChange = (event: ChangeEventType) => {
    let newErrorText = '';
    const targetElement = event.target as HTMLInputElement;
    const newValue = targetElement.value.trim();
    if (newValue.length > dateFormat.length) return;
    const isValidDate = validateInput(newValue);
    if (newValue.length === dateFormat.length) {
      newErrorText = isValidDate ? '' : 'Invalid date provided';
    }

    setErrorText(newErrorText);
    setValue(newValue);
  };

  const handleBlur = (event: FocusEvent) => {
    if (errorText) {
      const targetElement = event.target as HTMLInputElement;
      const newValue = targetElement.value.trim();
      const isValidDate = validateInput(newValue);
      const newErrorText = isValidDate ? '' : 'Invalid date provided';

      setValue(newValue);
      setErrorText(newErrorText);
    }
  };

  const handleFocus = () => {
    if (errorText) {
      setErrorText('');
    }
  };

  return (
    <div>
      <DatePicker
        enableAutoFormatting
        label="Reconciliation date"
        locale={locale}
        dateFormat={dateFormat}
        announcementCurrentDate="date actuelle"
        value={value}
        automationId="dpFrench"
        errorText={errorText}
        onChange={handleInputChange}
        onBlur={handleBlur}
        onFocus={handleFocus}
      />
    </div>
  );
}
