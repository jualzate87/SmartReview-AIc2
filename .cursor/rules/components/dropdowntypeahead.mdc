<summary>Full TypeScript Interface</summary>

```typescript
export interface DropdownTypeaheadProps
  extends Omit<ThemeableElement<'div'>, 'onChange'>,
    DropdownTypeaheadStateProps {
  /**
   * Determine whether DropdownTypeahead render add-new Menu Item
   *
   * @default false
   */
  addNew?: boolean;
  /**
   * 0-based index of where to insert the add-new Menu item into the menu. 0 inserts it as the first element. any number large than dataSource.length puts it at the end.
   *
   * @default 0
   */
  addNewIndex?: number;
  /** The props need to pass down to add-new Menu Item */
  addNewItemProps?: any;
  /**
   * The text for add-new Menu Item, default is 'Add'
   *
   * @default 'Add'
   */
  addNewText?: string;
  /** Used for accessibility purposes. */
  'aria-label'?: string;
  /**
   * Used for accessibility purposes.
   *
   * @default false
   */
  'aria-required'?: boolean;
  /** Function that will assign the text field input ref to the ref.current passed in by consumers */
  assignInputRef?: (ref: HTMLInputElement | null) => void;
  /** Id used for automation testing */
  automationId?: string;
  /** The dataSource is array of object used for rendering MenuItems. This prop is REQUIRED. */
  dataSource: Array<Record<string, any>>;
  /**
   * Disable dropdown if true.
   *
   * @default false
   */
  disabled?: boolean;
  /**
   * focusOnRender if true brings focus on the initial render
   *
   * @default false
   */
  focusOnRender?: boolean;
  /** Error message to be rendered. */
  errorText?: string;
  /**  renders error styles in text field. */
  validationError?: boolean;
  /** helper message to be rendered. */
  helperText?: string;
  /** Info message to be rendered. */
  infoText?: string;
  /** A string value need to pass down to TextField. This prop is REQUIRED */
  inputValue: string;
  /** Label to be displayed for the TextField. */
  label?: string;
  /** Class to be applied to menu. */
  menuClass?: string;
  /**
   * Enable Multi Select dropdown if true
   *
   * @default false
   */
  multiselect?: boolean;
  /** Callback function to execute on DropdownTypeahead get blurred. */
  onBlur?: ReactEventHandler;
  /**
   * Callback function to be executed when a MenuItem gets selected.
   * The signature is: onChange(event, { selectedItem, highlightedIndex, method }),
   * where 'event' - the actual DOM event object, which is either the menu-item div or text-input,
   *       'selectedItem' - the selected item,
   *       'highlightedIndex' - the index of highlighted item in Menu,
   *       'method' - string to tell how user selected the item: 'click' or 'enter'.
   */
  onChange?: (event: ReactEvent, infoObject?: OnChangeInfoType) => void;
  /** Callback function to be executed when the DropdownTypeahead gets clicked. */
  onClick?: ReactEventHandler;
  /** Callback function to be executed when the menu gets closed. */
  onClose?: () => void;
  /** Callback function to be executed when the DropdownTypeahead gets focus. */
  onFocus?: React.FocusEventHandler;
  /**
   * Callback function to execute when user press a key in the TextField.
   * The signature is: onKeyDown(event, { highlightedItem, highlightedIndex }),
   * where 'event' - the actual DOM event object, which is text-input,
   *       'highlightedItem' - the highlighted item,
   *       'highlightedIndex' - the index of highlighted item in Menu,
   * If key name is 'Enter' and an item is highlighted, it will fire onChange callback as well.
   */
  onKeyDown?: (
    event: React.KeyboardEvent,
    infoObject?: OnKeyDownInfoType
  ) => void;
  /** Callback function to execute when user typing in the TextField. */
  onSearch?: (e: React.ChangeEvent<HTMLInputElement>) => void;
  /** Placeholder to be displayed for the TextField. */
  placeholder?: string;
  /**
   * preventMenuOverflow: an object variable; used to prevent DropdownTypeahead Menu from being positioned outside the boundary.
   *  More detail in @ids-ts/position preventOverflow API document.
   */
  preventMenuOverflow?: PreventOverflow;
  /**
   * To set the component to "readonly" mode. Input will not be accepted but still focusable for a11y. The dropdown menu will be disabled.
   */
  readOnly?: boolean;
  /**
   * A required function is used for rendering MenuItems. This prop is REQUIRED.
   * First "data" argument must present, second "index" argument is optional.
   * The return item mush be any React element.
   */
  renderItem: (
    data: DropdownTypeaheadStateProps & Record<string, any>,
    /** index in the array */
    index?: number
  ) => JSX.Element;
  /**
   * An option to select all input text when DropdownTypeahead gets keyboard TAB in focused.
   *
   * @default false
   */
  selectTextOnFocus?: boolean;
  /**
   * Determine whether it shows checkmark for selected Menu Item
   *
   * @default false
   */
  showCheckmark?: boolean;
  /** Size to render the TextField at */
  size?: TextFieldProps['size'];
  /** The optional styles applied to the position node wrapped around the root node. */
  stylePosition?: React.CSSProperties;
  /** suggestedText to be displayed for the TextField. */
  suggestedText?: string;
  /** id to override the generated id that gets applied to underlying textfield */
  textFieldId?: string;
  /** theme class from theme wrapper */
  themeClass?: string;
  /** Selected value. This prop is REQUIRED */
  value: string | string[];
  /** Warning message to be rendered. */
  warningText?: string;
  /** Width prop to set a custom width needed for TextField */
  width?: string;
}

