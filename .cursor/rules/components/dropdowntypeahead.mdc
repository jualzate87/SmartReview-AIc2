### Loading State

```tsx
() => {
  const [loading, setLoading] = React.useState(true);
  const {
    value,
    inputValue,
    handleBlur,
    handleChange,
    handleClick,
    handleKeyDown,
    handleInputChange
  } = useDropdownTypeaheadState();
  const dataSource = loading ? [] : itemData;

  React.useEffect(() => {
    const timeoutId = window.setTimeout(() => {
      setLoading(false);
    }, 6000); // show loader for 6 seconds

    return () => {
      window.clearTimeout(timeoutId);
    };
  }, []);

  const handleRenderItem: DropdownTypeaheadProps['renderItem'] = (
    { isLoading, loadingAriaLabel, value: itemValue, label },
    index
  ) => {
    if (isLoading) {
      return <LoadingMenuItem loadingAriaLabel={loadingAriaLabel} />;
    }

    return (
      <MenuItem key={index} value={itemValue}>
        {label}
      </MenuItem>
    );
  };

  return (
    <DropdownTypeahead
      isLoading={loading}
      loadingAriaLabel="Data Loading..."
      automationId="basicDTA"
      label="Loading state"
      dataSource={dataSource}
      inputValue={inputValue}
      renderItem={handleRenderItem}
      value={value}
      onBlur={handleBlur}
      onChange={handleChange}
      onClick={handleClick}
      onKeyDown={handleKeyDown}
      onSearch={handleInputChange}
    />
  );
}
