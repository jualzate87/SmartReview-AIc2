### Multiselect Feature

```tsx
() => {
  const [selectedValues, setSelectedValues] = React.useState([
    itemData[1].value,
    itemData[3].value
  ]);
  const [selectedLabels, setSelectedLabels] = React.useState([
    itemData[1].label,
    itemData[3].label
  ]);
  const [showFullData, setShowFullData] = React.useState(true);
  const [inputValue, setInputValue] = React.useState(selectedLabels.join(', '));

  const handleChange = (
    e: ReactEvent,
    infoObject: OnChangeInfoType | undefined
  ) => {
    const selectedItem = infoObject ? infoObject.selectedItem : undefined;

    if (!selectedItem || !selectedItem.value || !selectedItem.label) {
      return;
    }

    const updatedValues = [...selectedValues];
    const updatedLabels = [...selectedLabels];

    if (updatedValues.includes(selectedItem.value)) {
      updatedValues.splice(updatedValues.indexOf(selectedItem.value), 1);
      updatedLabels.splice(updatedLabels.indexOf(selectedItem.label), 1);
    } else {
      updatedValues.push(selectedItem.value);
      updatedLabels.push(selectedItem.label);
    }

    setSelectedValues(updatedValues);
    setSelectedLabels(updatedLabels);
    setInputValue(updatedLabels.join(', '));
    setShowFullData(true);
  };

  const handleClick = () => {
    setShowFullData(true);
  };

  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    setShowFullData(false);
    setInputValue(e.target.value);
  };

  const handleClose = () => {
    setShowFullData(true);
    setInputValue(selectedLabels.join(', '));
  };

  const handleRenderItem: DropdownTypeaheadProps['renderItem'] = (data) => {
    return <MenuItem value={data.value}>{data.label}</MenuItem>;
  };

  const data = showFullData ? itemData : filterData(itemData, inputValue);

  return (
    <DropdownTypeahead
      multiselect
      showCheckmark
      selectTextOnFocus
      automationId="multiselectDTA"
      aria-label="Fruit"
      dataSource={data}
      inputValue={inputValue}
      renderItem={handleRenderItem}
      value={selectedValues}
      onChange={handleChange}
      onClick={handleClick}
      onSearch={handleInputChange}
      onClose={handleClose}
    />
  );
}
```

