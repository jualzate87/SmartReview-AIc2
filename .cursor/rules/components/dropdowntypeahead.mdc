## Code Example

```tsx
import React from 'react';
import { DropdownTypeahead, MenuItem } from '@ids-ts/dropdown-typeahead';

export const itemData = [
  { value: '0', label: 'Banana' },
  { value: '1', label: 'Apple' },
  { value: '2', label: 'Guava' },
  { value: '3', label: 'Mango' },
  { value: '4', label: 'Broccoli' },
  { value: '5', label: 'Carrot' },
  { value: '6', label: 'Cherry' },
  { value: '7', label: 'Melon' },
  { value: '8', label: 'Pineapple' },
  { value: '9', label: 'Cereal' },
  { value: '10', label: 'Grape' },
  { value: '11', label: 'Kiwi' }
];

export const filterData = (data, inputValue) => {
  if (!inputValue) {
    return data;
  }

  return data.filter(
    (item) => item.label.toLowerCase().indexOf(inputValue.toLowerCase()) > -1
  );
};

export const ExampleDropdownTypeahead = () => {
  const [value, setValue] = React.useState('');
  const [inputValue, setInputValue] = React.useState('');
  const [showFullData, setShowFullData] = React.useState(true);

  const handleBlur = (e) => {
    const relatedElement = e.relatedTarget;
    const targetElement = e.target;

    const valueElement =
      targetElement.value === undefined
        ? relatedElement.innerText
        : targetElement.value;
    const data = itemData.filter(
      (item) =>
        valueElement && item.label.toLowerCase() === valueElement.toLowerCase()
    );
    const newValue = data.length > 0 ? data[0].value : '';
    const newInputValue = newValue ? data[0].label : '';
    setValue(newValue);
    setInputValue(newInputValue);
    setShowFullData(true);
  };

  const handleChange = (e, info) => {
    const { selectedItem } = info || {};
    if (!selectedItem || !selectedItem.value || !selectedItem.label) {
      return;
    }

    setInputValue(selectedItem.label);
    setShowFullData(true);
    setValue(selectedItem.value);
  };

  const handleClick = () => {
    setShowFullData(true);
  };

  const handleKeyDown = (e) => {
    if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
      const targetElement = e.target;
      const data = filterData(itemData, targetElement.value);
      if (value || data.length === 0) {
        setShowFullData(true);
      }
    }
  };

  const handleInputChange = (e) => {
    const targetElement = e.target;
    setShowFullData(false);
    setInputValue(targetElement.value);
    setValue('');
  };

  const handleRenderItem = (data) => {
    return <MenuItem value={data.value}>{data.label}</MenuItem>;
  };

  const data = showFullData ? itemData : filterData(itemData, inputValue);

  return (
    <DropdownTypeahead
      label="Example Label"
      dataSource={data}
      inputValue={inputValue}
      renderItem={handleRenderItem}
      value={value}
      onBlur={handleBlur}
      onChange={handleChange}
      onClick={handleClick}
      onKeyDown={handleKeyDown}
      onSearch={handleInputChange}
    />
  );
};

export default ExampleDropdownTypeahead;
```

