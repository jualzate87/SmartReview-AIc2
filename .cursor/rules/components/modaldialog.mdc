### Back Button Example

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [firstPage, setFirstPage] = useState(true);

  const handleOpen = () => setOpen(true);
  const handleClose = () => setOpen(false);

  const handleNext = () => setFirstPage(false);
  const handleBack = () => setFirstPage(true);

  return (
    <>
      <Button onClick={handleOpen}>Open Back Button Example</Button>
      <Modal dismissible open={open} onClose={handleClose}>
        <ModalHeader
          backActionLabel={firstPage ? undefined : 'Go back'}
          onBackActionClick={firstPage ? undefined : handleBack}
        >
          <ModalTitle
            title={
              firstPage ? 'aria-autocomplete' : 'aria-autocomplete description'
            }
          />
        </ModalHeader>
        <ModalContent>
          {firstPage && (
            <>
              <B2>
                The aria-autocomplete attribute indicates whether inputting text
                could trigger display of one or more predictions of the
                user&apos;s intended value for a combobox, searchbox, or textbox
                and specifies how predictions will be presented if they are
                made.
              </B2>
              <Button onClick={handleNext}>
                Learn More about aria-autocomplete
              </Button>
            </>
          )}
          {!firstPage && (
            <B2>
              Autocompletion is user interface feature wherein inline
              suggestions are made as a user types in an input. Suggested text
              for completing the value of the field dynamically appears in the
              field after the input cursor, and the suggested value becomes the
              value if the user performs an action, such as tabbing, that causes
              focus to leave the field.
            </B2>
          )}
        </ModalContent>
        <ModalActions>
          <Button priority="tertiary" onClick={handleClose}>
            Dismiss
          </Button>
        </ModalActions>
      </Modal>
    </>
  );
}
```

### Modal With Drawer On Top

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [openDrawer, setOpenDrawer] = useState(false);

  const handleOpen = () => setOpen(true);
  const handleClose = () => setOpen(false);
  const handleOpenDrawer = () => setOpenDrawer(true);
  const handleCloseDrawer = () => setOpenDrawer(false);

  return (
    <>
      <Button onClick={handleOpen}>
        Open Modal with Drawer on Top Example
      </Button>
      <Modal open={open} onClose={handleClose}>
        <ModalHeader>
          <ModalTitle title="aria-checked" />
        </ModalHeader>
        <ModalContent>
          <B2>
            The aria-checked attribute indicates the current &quot;checked&quot;
            state of checkboxes, radio buttons, and other widgets. Note: Where
            possible use an HTML &lt;input&gt; element with
            type=&quot;checkbox&quot; and type=&quot;radio&quot; as these have
            built in semantics and do not require ARIA attributes.
          </B2>
          <br />
          <Button id="open_drawer_sizes_example" onClick={handleOpenDrawer}>
            Learn more about aria-checked
          </Button>
          <Drawer
            backdrop
            open={openDrawer}
            size="small"
            onClose={handleCloseDrawer}
            onShow={handleOpenDrawer}
          >
            <DrawerHeader title="aria-checked" onClose={handleCloseDrawer} />
            <DrawerContent>
              <B2>
                The aria-checked attribute indicates whether the element is
                checked (true), unchecked (false), or if the checked status is
                indeterminate (mixed), meaning it is neither checked nor
                unchecked. The mixed value is supported by the tri-state input
                roles of checkbox and menuitemcheckbox.
                <br />
                The mixed value is not supported on radio, menuitemradio, or
                switch and elements that inherits from these. The value will be
                false if mixed is set when not supported.
                <br />
                The tabindex attribute is required to enable focus. JavaScript
                is required to toggle the aria-checked state. And, if this
                checkbox is part of a submittable form, more JavaScript is
                required to set a name and a value.
              </B2>
            </DrawerContent>
            <DrawerFooter
              footerPrimaryAction={
                <Button purpose="standard" onClick={handleCloseDrawer}>
                  Primary Dismiss
                </Button>
              }
              footerSecondaryAction={
                <Button
                  purpose="passive"
                  priority="secondary"
                  onClick={handleCloseDrawer}
                >
                  Secondary Dismiss
                </Button>
              }
            />
          </Drawer>
        </ModalContent>
        <ModalActions>
          <Button priority="tertiary" onClick={handleClose}>
            Dismiss
          </Button>
        </ModalActions>
      </Modal>
// ...
```

