## Usage Patterns

### Basic

```tsx
() => {
  const [open, setOpen] = useState(false);
  const handleOpen = () => setOpen(true);
  const handleClose = () => setOpen(false);

  return (
    <>
      <Button onClick={handleOpen}>Open Basic Example</Button>
      <Modal open={open} onClose={handleClose}>
        <ModalHeader>
          <ModalTitle title="aria-activedescendant" />
        </ModalHeader>
        <ModalContent>
          The aria-activedescendant attribute identifies the currently active
          element when focus is on a composite widget, combobox, textbox, group,
          or application.
        </ModalContent>
        <ModalActions>
          <Button priority="tertiary" onClick={handleClose}>
            Dismiss
          </Button>
        </ModalActions>
      </Modal>
    </>
  );
}
```

### Modal With Multi Select Dropdown

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [values, setValues] = useState([]);

  const handleOpen = () => setOpen(true);
  const handleClose = () => setOpen(false);

  const onChangeMultiSelect = (e: KeyboardEvent | MouseEvent) => {
    const target = e.target as HTMLSelectElement;
    action('Selected Value:')(values.toString());
    if (values.includes(target.value as never)) {
      values.splice(values.indexOf(target.value as never), 1);
      setValues(values);
    } else {
      values.push(target.value as never);
      setValues(values);
    }
  };

  return (
    <>
      <Button onClick={handleOpen}>
        Open Modal With Multiselect Dropdown Example
      </Button>
      <Modal open={open} onClose={handleClose}>
        <ModalHeader>
          <ModalTitle title="Pick your favorite continent" />
        </ModalHeader>
        <ModalContent>
          <Dropdown
            multiselect
            width="305px"
            label="Select your favorite continents (all that apply)"
            placeholder="ex: Antarctica, North America, etc."
            id="multiselect"
            value={values}
            onChange={onChangeMultiSelect as any}
          >
            <MenuItem value="1">Africa</MenuItem>
            <MenuItem value="2">Antarctica</MenuItem>
            <MenuItem value="3">Asia</MenuItem>
            <MenuItem value="4">Europe</MenuItem>
            <MenuItem value="5">Oceania</MenuItem>
            <MenuItem value="6">North America</MenuItem>
            <MenuItem value="7">South America</MenuItem>
          </Dropdown>
        </ModalContent>
        <ModalActions>
          <Button priority="tertiary" onClick={handleClose}>
            Dismiss
          </Button>
        </ModalActions>
      </Modal>
    </>
  );
}
```

### Modal With All Buttons

```tsx
() => {
  const [open, setOpen] = useState(false);

  const handleOpen = () => setOpen(true);
