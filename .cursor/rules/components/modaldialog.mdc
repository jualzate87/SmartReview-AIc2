## Code Example

```tsx
it('should render a modal', async () => {
  const app = await render(
    <Modal>
      <ModalHeader>
        <ModalTitle title="Modal Title" />
      </ModalHeader>
      <ModalContent overflow maxHeight="50vh">
        {'Modal Content'}
      </ModalContent>
      <ModalActions>{'Actions Here'}</ModalActions>
    </Modal>
  );
  expect(app.baseElement).toMatchSnapshot();
});
```

