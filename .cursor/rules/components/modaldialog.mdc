        </ModalHeader>
        <ModalContent>
          In ARIA live regions, the global aria-atomic attribute indicates
          whether assistive technologies such as a screen reader will present
          all, or only parts of, the changed region based on the change
          notifications defined by the aria-relevant attribute.
        </ModalContent>
        <ModalActions>
          <Button priority="tertiary" purpose="standard" onClick={handleClose}>
            Standard Dismiss
          </Button>
          <Button priority="tertiary" purpose="passive" onClick={handleClose}>
            Passive Dismiss
          </Button>
          <Button priority="tertiary" purpose="special" onClick={handleClose}>
            Special Dismiss
          </Button>
          <Button
            priority="primary"
            purpose="destructive"
            onClick={handleClose}
          >
            Destructive Dismiss
          </Button>
        </ModalActions>
      </Modal>
    </>
