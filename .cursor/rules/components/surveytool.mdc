## Usage Patterns

### Basic Sentiment Question Usage

```tsx
() => {
  return (
    <div>
      <H5>Basic usage - see actions tab below for tracking information</H5>
      <SurveyTool
        question={question}
        analyticsKey="CIS_EFILING"
        sandbox={mockSandbox}
        scopeArea="taxes"
        onSubmit={action('onSubmit')}
        onSurveyComplete={action('onSurveyComplete')}
      />
    </div>
  );
}
```

### Analytics Version

```tsx
() => {
  return (
    <div>
      <H5>
        Analytics Version - see actions tab below for tracking information
      </H5>
      <SurveyTool
        question={question}
        analyticsKey="CIS_EFILING"
        analyticsVersion="VER1"
        sandbox={mockSandbox}
        scopeArea="taxes"
        onSubmit={action('onSubmit')}
        onSurveyComplete={action('onSurveyComplete')}
      />
    </div>
  );
}
```

### Success Message

```tsx
() => {
  return (
    <div>
      <H5>
        Successful submitted Message - see actions tab below for tracking
        information
      </H5>
      <SurveyTool
        question={question}
        analyticsKey="CIS_EFILING"
        sandbox={mockSandbox}
        scopeArea="taxes"
        submittedMessage={submittedMessage}
        onSubmit={action('onSubmit')}
        onSurveyComplete={action('onSurveyComplete')}
      />
    </div>
  );
}
```

### Follow Up Verbatim Question With Success Message

```tsx
() => {
  return (
    <div>
      <H5>
        Verbatim Question - see actions tab below for tracking information
      </H5>
      <SurveyTool
        question={question}
        analyticsKey="CIS_EFILING"
        sandbox={mockSandbox}
        scopeArea="taxes"
        submittedMessage={submittedMessage}
        verbatimButton={verbatimButton}
        collectVerbatimFor={{
          [ResponseKey.negative]: verbatimQuestion,
          [ResponseKey.neutral]: verbatimQuestion,
          [ResponseKey.positive]: verbatimQuestionPositive
        }}
        onSubmit={action('onSubmit')}
        onSurveyComplete={action('onSurveyComplete')}
        onVerbatimSubmit={action('onVerbatimSubmit')}
      />
    </div>
  );
}
```

