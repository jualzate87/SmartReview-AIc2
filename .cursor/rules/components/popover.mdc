### Custom Fade Only Animations

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [targetElement, setTargetElement] = useState<HTMLElement | null>(null);

  const handleOpen = (event: React.MouseEvent<HTMLButtonElement>) => {
    setTargetElement(event.currentTarget);
    setOpen(true);
  };

  const handleClose = () => {
    setOpen(false);
  };

  return (
    <div style={{ padding: 'var(--space-container-padding-medium)' }}>
      <PageMessage
        open
        title="✨ Custom animations"
        type="discovery"
        dismissible={false}
        style={{ marginBottom: 'var(--space-container-padding-medium)' }}
      >
        <B3>
          This popover uses custom fade-only animations instead of the default
          scale+fade. Notice the smooth fade in/out without any scaling effect.
        </B3>
        <pre
          style={{
            display: 'block',
            fontSize: 'var(--font-size-body-4)',
            padding: 'var(--space-component-gap-medium)',
            fontFamily: 'monospace',
            marginTop: 'var(--space-component-gap-large)'
          }}
        >
          {`animationProperties={{
  transitionEnter: 'example-popover-fadein',
  transitionExit: 'example-popover-fadeout'
}}

unmountDelay={1000} // duration of the animation`}
        </pre>
      </PageMessage>

      <Button purpose="standard" priority="primary" onClick={handleOpen}>
        Open custom fade animation
      </Button>

      <Popover
        dismissible
        open={open}
        targetElement={targetElement}
        position="bottom"
        alignment="center"
        animationProperties={{
          transitionEnter: styles['example-popover-fadein'],
          transitionExit: styles['example-popover-fadeout']
        }}
        unmountDelay={1000}
        onClose={handleClose}
      >
        <PopoverHeader title="Fade-only animation" />
        <PopoverContent>
          <B3 as="p">This popover uses custom fade-only animations!</B3>
          <B3 as="p">
            No scaling effect - just smooth opacity transitions that respect
            prefers-reduced-motion settings.
