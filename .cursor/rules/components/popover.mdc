## Usage Patterns

### Basic

```tsx
() => {
  const [open, setOpen] = useState(false);
  const [position, setPosition] = useState<Positions | undefined>(undefined);
  const [alignment, setAlignment] = useState<Alignments | undefined>(undefined);
  const [target, setTarget] = useState<Element | Text | null>(null);
  const buttonRef = React.createRef<HTMLButtonElement>();

  const handleClose = () => {
    setOpen(false);
  };

  return (
    <div>
      <Button
        innerRef={buttonRef}
        aria-haspopup="dialog"
        purpose="standard"
        priority="primary"
        onClick={() =>
          handleClick(
            'left',
            'top',
            buttonRef as React.MutableRefObject<HTMLButtonElement>,
            open,
            target,
            setOpen,
            setTarget,
            setPosition,
            setAlignment
          )
        }
      >
        Basic
      </Button>
      <Popover
        dismissible
        open={open}
        targetElement={target as HTMLElement}
        position={position}
        alignment={alignment}
        onClose={handleClose}
      >
        <PopoverHeader title="Popover title" />
        <PopoverContent>
          <TextField label="Field label" width="100%" />
        </PopoverContent>
        <PopoverActions>
          <Button purpose="standard" priority="primary" onClick={handleClose}>
            Primary
          </Button>
          <Button purpose="standard" priority="secondary">
            Secondary
          </Button>
        </PopoverActions>
      </Popover>
    </div>
  );
}
```

