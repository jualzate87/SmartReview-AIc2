# Popover

Popovers are used to provide quick actions without taking the user away from the page.

A temporary menu that is revealed upon a user’s interaction with a button, action or other control.
This allows users to access a list of choices and/or actions.

## Installation & Import

```bash
yarn add @ids-ts/popover
```

```tsx
import {
  Popover,
  PopoverHeader,
  PopoverContent,
  PopoverActions,
} from '@ids-ts/popover';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `alignment` | `Alignments` | Yes | Alignment of popover to target (e.g., `'top'`, `'middle'`, `'left'`, `'right'`). |
| `animationOn` | `boolean` | Yes | - |
| `children` | `React.ReactElement | React.ReactElement[]` | Yes | Inner content of popover |
| `enableClickAway` | `boolean` | No | Disable onClose trigger on click away when dismissible is true. |
| `disableAutoFocus` | `boolean` | No | - |
| `disableRestoreFocus` | `boolean` | No | If true, does not focus back on the element that initiated |
| `dismissible` | `boolean` | No | - |
| `onClose` | `React.ReactEventHandler` | Yes | On close callback. |
| `onPosition` | `(popoverRef: React.Ref<HTMLDivElement>) => void` | No | Callback with the popover ref after positioning. |
| `open` | `boolean` | Yes | - |
| `popoverOffsetX` | `number` | No | - |
| `popoverOffsetY` | `number` | No | - |
| `popoverOffsetSkidding` | `number` | No | Cross-axis pixel offset of the popover. |
| `popoverOffsetDistance` | `number` | No | Main-axis pixel offset of the popover. |
| `position` | `Positions` | Yes | Position of the popover: `'top'`, `'bottom'`, `'left'`, `'right'`. |
| `preventOverflow` | `PreventOverflow` | No | - |
| `stylePosition` | `React.CSSProperties` | No | * The optional styles applied to the position node wrapped around the root node. |
| `targetElement` | `React.ReactNode | HTMLElement` | Yes | - |
| `variant` | `'popover' | 'flyout'` | Yes | - |
| `suppressPointer` | `boolean` | Yes | - |
| `unmountDelay` | `number` | Yes | - |
| `animationProperties` | `{ enterClassName?: string; exitClassName?: string }` | No | CSS class names for enter and exit animations. |
| `transitionExit` | `string` | No | * The className to apply when the popover is exiting. |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface PopoverProps extends ThemeableElement<'div'> {
  /**
   * Alignment of popover to target.
   * alignment: string of alignments
   * vertical alignments: top, bottom, middle
   * horizontal alignments: left, right, center
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   * If multiple given, the first or the one with enough space will be chosen.
   *
   * @default 'middle'
   */
  alignment: Alignments;
  /**
   * Whether animation is turned on.
   *
   * @default true
   */
  animationOn: boolean;
  /** non-visual text description that describes the popover's purpose. It is surfaced to assistive technology. */
  'aria-label'?: string;
  /** Inner content of popover */
  children: React.ReactElement | React.ReactElement[];
  /** Disable onClose trigger on click away when dismissible is true. */
  enableClickAway?: boolean;
  /**
   * If true, does not put focus on first tabbable element.
   * You will need to tab or add your own keyboard handler to make the
   * first element tabbable.
   */
  disableAutoFocus?: boolean;
  /** If true, does not focus back on the element that initiated */
  disableRestoreFocus?: boolean;
  /** Flag to set Popover as dismissible.
   * When using the keyboard Popover traps focus, when setting dismissible to false
   * make sure you have a button or action to close the Popover otherwise
   * people will be trap without a way to close the Popover.
   */
  dismissible?: boolean; // keep for flexibility
  /** On close callback. */
  onClose: React.ReactEventHandler;
  /**
   * Callback invoked after initial open positioning and window resize.
   *
   * @param popoverRef
   * @param popoverWrapper
   * @returns
   */
  onPosition: (
    popoverRef: React.Ref<HTMLDivElement>,
    popoverWrapper: React.Ref<HTMLDivElement | null>
  ) => void;
  /**
   * Whether component open.
   *
   * @default false
   */
  open: boolean;
  /** Offset popover on X axis; gives user more flexibility on where the caret is (see Position)
   *
   * @deprecated Please use popoverOffsetSkidding instead
   */
  popoverOffsetX?: number;
  /** Offset popover on Y axis
   *
   * @deprecated Please use popoverOffsetDistance instead
   */
  popoverOffsetY?: number;
  /**
   * popoverOffsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  popoverOffsetSkidding: number;
  /**
   * popoverOffsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  popoverOffsetDistance: number;
  /**
   * Position for popover to be placed.
   * position: string of positions to try
   * vertical positions: top, bottom
   * horizontal positions: left, right
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   * If multiple given, the first or the one with enough space will be chosen.
   *
   * @default 'top'
   */
  position: Positions;
  /**
   * an object variable; used to prevent Popover from being positioned outside the boundary.
   * More detail in @ids/position preventOverflow API document.
   * Also see react popper library and IDS Dropdown Typeahead.
   */
  preventOverflow?: PreventOverflow;
  /**
   * The optional styles applied to the position node wrapped around the root node.
   */
  stylePosition?: React.CSSProperties;
  /**
   * an HTML DOM element
   * The HTML DOM element to be used as the target reference.
   */
  targetElement: React.ReactNode | HTMLElement;
  /**
   * Prop to set variant for the popover component
   *
   * @default 'popover'
   */
  variant: 'popover' | 'flyout';
  /**
   * Whether or not to display styled pointer
   *
   * @default false
   */
  suppressPointer: boolean;
  /**
   * Delay component unmount by this amount of ms. Supports running exit
   * animations smoothly
   */
  unmountDelay: number;
  /**
   * Specifies custom class names for transition enter and/or exit animations.
   * The consumer is responsible for defining the animation rules associated with these classes.
   */
  animationProperties?: {
    /**
     * The className to apply when the popover is entering.
     */
    transitionEnter?: string;
    /**
     * The className to apply when the popover is exiting.
     */
    transitionExit?: string;
  };
}
```

</details>

