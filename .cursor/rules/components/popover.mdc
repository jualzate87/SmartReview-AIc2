## Code Example

```tsx
import React from 'react';
import Popover from '@ids-ts/popover';
// if you need it, don't forget to import the styles too.
import '@ids-ts/popover/dist/main.css';

const PopoverExample = () => {
  const handleClick = (
    p: Positions,
    a: Alignments,
    ref: React.MutableRefObject<HTMLButtonElement>,
    open: boolean,
    curTarget: Element | Text | null,
    setOpen: React.Dispatch<React.SetStateAction<boolean>>,
    setTarget: React.Dispatch<React.SetStateAction<Element | Text | null>>,
    setPosition: React.Dispatch<React.SetStateAction<Positions | undefined>>,
    setAlignment: React.Dispatch<React.SetStateAction<Alignments | undefined>>
  ) => {
    const newTarget = ReactDOM.findDOMNode(ref.current);
    newTarget === curTarget ? setOpen(!open) : setOpen(true);
    setTarget(newTarget);
    setPosition(p);
    setAlignment(a);
  };

  const [open, setOpen] = useState(false);
  const [position, setPosition] = useState<Positions | undefined>(undefined);
  const [alignment, setAlignment] = useState<Alignments | undefined>(undefined);
  const [target, setTarget] = useState<Element | Text | null>(null);
  const buttonRef = React.createRef<HTMLButtonElement>();

  const handleClose = () => {
    setOpen(false);
  };

  return (
    <div>
      <Button
        innerRef={buttonRef}
        aria-haspopup="dialog"
        purpose="standard"
        priority="solid"
        onClick={() =>
          handleClick(
            'left',
            'top',
            buttonRef as React.MutableRefObject<HTMLButtonElement>,
            open,
            target,
            setOpen,
            setTarget,
            setPosition,
            setAlignment
          )
        }
      >
        Basic
      </Button>
      <Popover
        dismissible
        open={open}
        targetElement={target}
        position={position}
        alignment={alignment}
        variant="popover"
        onClose={handleClose}
      >
        <PopoverHeader title="Popover title" />
        <PopoverContent>
          <TextField label="Field Label" width="100%" theme="quickbooks" />
        </PopoverContent>
        <PopoverActions>
          <Button
            purpose="passive"
            priority="solid"
            theme="quickbooks"
            onClick={handleClose}
          >
            Primary
          </Button>
          <Button purpose="passive" priority="ghost" theme="quickbooks">
            Secondary
          </Button>
        </PopoverActions>
      </Popover>
    </div>
  );
}

export default PopoverExample;
```

