## Usage Patterns

### Basic

```tsx
() => (
  <div
    style={{
      height: 200,
      width: '50%',
      marginTop: 50,
      marginLeft: 100,
      marginRight: 'auto'
    }}
  >
    <PointOfNeed
      message="Point of need tooltip"
      alignment="left"
      containerRef={() => undefined}
      duration={0}
      enableClickAway={false}
      offsetX={0}
      offsetY={0}
      position="left"
      tooltipOffsetSkidding={0}
      tooltipOffsetDistance={0}
      delayOpen={false}
      delayOpenDuration={0}
    />
```

### Showcase

```tsx
() => {
  return (
    <div>
      <PointOfNeed
        message="Point of need tooltip"
        alignment="left"
        containerRef={() => undefined}
        duration={0}
        enableClickAway={false}
        offsetX={0}
        offsetY={0}
        position="left"
        tooltipOffsetSkidding={0}
        tooltipOffsetDistance={0}
        delayOpen={false}
        delayOpenDuration={0}
      />
    </div>
  );
}
```

