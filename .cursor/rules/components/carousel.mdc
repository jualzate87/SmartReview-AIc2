## Usage Patterns

### Playground

```tsx
() => {
  const chips = [
    {
      header: 'Date',
      content: ['1/1/24-1/31/24', '1/1/24-1/31/24']
    },
    {
      header: 'Sort',
      content: ['Date', 'Transaction Type']
    },
    { header: 'Amount', content: ['$34.00'] },
    {
      header: 'Payee',
      content: ['John Doe', 'Nicole Martin']
    },
    {
      header: 'Date',
      content: ['9/2/24-11/12/24', '10/1/24-11/03/24']
    },
    { header: 'Reference Number', content: ['9018'] },
    { header: 'Transaction Type', content: ['Bill'] },
    {
      header: 'Sort',
      content: ['Transaction Type', 'Payee']
    }
  ];
  const [chipArray, setChipArray] = useState(chips);
  const handleClose = (i: number) => {
    const newChipArray = chipArray.slice();
    newChipArray.splice(i, 1);
    setChipArray(newChipArray);
  };

  return (
    <Carousel>
      {chipArray.map((child, i) => {
        return (
          <Chip
            header={child.header}
            selectionLabels={child.content}
            onClose={() => handleClose(i)}
          />
        );
      })}
    </Carousel>
  );
}
```

### Basic Usage

```tsx
() => {
  const chips = [
    {
      header: 'Date',
      isOpen: true,
      content: ['1/1/24-1/31/24', '1/1/24-1/31/24']
    },
    {
      header: 'Sort',
      isOpen: true,
      content: ['Date', 'Transaction Type']
    },
    { header: 'Amount', isOpen: true, content: ['$34.00'] },
    {
      header: 'Payee',
      isOpen: true,
      content: ['John Doe', 'Nicole Martin']
    },
    {
      header: 'Date',
      isOpen: true,
      content: ['9/2/24-11/12/24', '10/1/24-11/03/24']
    },
    { header: 'Reference Number', isOpen: true, content: ['9018'] },
    { header: 'Transaction Type', isOpen: true, content: ['Bill'] },
    {
      header: 'Sort',
      isOpen: true,
      content: ['Transaction Type', 'Payee']
    }
  ];
  const [chipArray, setChipArray] = useState(chips);
  const handleClose = (i: number) => {
    const newChipArray = chipArray.slice();
    newChipArray.splice(i, 1);
    setChipArray(newChipArray);
  };

  return (
    <Carousel>
      {chipArray.map((child, i) => {
        return (
          <Chip
            header={child.header}
            selectionLabels={child.content}
            onClose={() => handleClose(i)}
          >
            {child.content}
          </Chip>
        );
      })}
    </Carousel>
  );
}
```

