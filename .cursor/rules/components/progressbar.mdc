### Animated

```tsx
() => {
  const count = [0, 13, 25, 38, 50, 63, 75, 88, 100];
  const [flag, setFlag] = useState(false);
  const [currentValue, setCurrentValue] = useState(count[0]);
  if (!flag) {
    count.forEach((element, index) => {
      if (index !== 0) {
        setTimeout(() => {
          setCurrentValue(element);
        }, 700 * index);
      }
    });
    setFlag(true);
  }

  return (
    <div style={displayWidthStyle}>
      <ProgressBar
        value={currentValue}
        counterElement={<Counter max={100} value={currentValue} />}
      />
    </div>
  );
}
```

