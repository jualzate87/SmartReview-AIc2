## Usage Patterns

### Playground

```tsx
({
  alignment,
  buttonPriority,
  buttonPurpose,
  buttonSize,
  disabled,
  disableOption1,
  disableOption3,
  label,
  offsetDistance,
  offsetSkidding,
  position,
  maxHeight
}) => (
  <DropdownButton
    disabled={disabled}
    label={label}
    buttonPurpose={buttonPurpose}
    buttonPriority={buttonPriority}
    buttonSize={buttonSize}
    automationId="basic_example"
    position={position}
    alignment={alignment}
    offsetSkidding={offsetSkidding}
    offsetDistance={offsetDistance}
    maxHeight={maxHeight}
    onSelect={(e: any) => action('Clicked')(e.target.value)}
  >
```

### Showcase

```tsx
() => (
  <div>
    <div>
      <h3>Dropdown Purposes</h3>
      <div style={{ display: 'flex', alignItems: 'flex-start', gap: '20px' }}>
        {purposes.map((purpose) => (
          <DropdownButton
            key={purpose}
            label={upperCaseUtil(purpose)}
            buttonPurpose={purpose}
            automationId="primaryAction"
            className={styles.exampleDropdownButton}
            onClick={action('Dropdown Button has been clicked')}
            onSelect={(e: any) => action('Clicked')(e.target.value)}
          >
            <MenuItem value="Contribute">Contribute</MenuItem>
            <MenuItem value="FileBug">File bug</MenuItem>
            <MenuItem value="EnhDesign">Enhance design</MenuItem>
            <MenuItem value="ProSuggest">Provide suggestions</MenuItem>
          </DropdownButton>
        )
```

### Basic

```tsx
() => (
  <DropdownButton
    label="What is your favorite fruit?"
    automationId="basic_example"
    onSelect={(e: any) => action('Clicked')(e.target.value)}
  >
```

### Update Position

```tsx
() => {
  const [y, setY] = useState(0);

  useEffect(() => {
    const timerId = setInterval(() => {
      setY((oldY) => (oldY + 100) % 600);
    }, 1500);

    return () => {
      clearInterval(timerId);
    };
  }, []);

  return (
    <DropdownButton
      label="Choose a site"
      automationId="basic_example"
      positionDependencies={[y]}
      style={{
        marginTop: y
      }}
      onSelect={(e: any) => action('Clicked')(e.target.value)}
    >
      <MenuItem value="Intuit">Intuit</MenuItem>
      <MenuItem value="Google">Google</MenuItem>
    </DropdownButton>
  );
}
```

### Log On Open

```tsx
() => {
  return (
    <DropdownButton
      label="Choose a site"
      automationId="basic_example"
      onSelect={(e: any) => action('Clicked')(e.target.value)}
      onOpen={action('Opened')}
    >
      <MenuItem value="Intuit">Intuit</MenuItem>
      <MenuItem value="Google">Google</MenuItem>
    </DropdownButton>
  );
}
```

