# DropdownButton

IDS DropdownButtons are primarily used when there are multiple actions available for an item or multiple items, none of which are considered to be primary action.
The IDS DropdownButton saves space and de-clutters the interface, but also hides the available actions within the drop menu.
The label on the IDS DropdownButton is not an action, but rather directs the user to open the dropdown menu to select an action.
The action is executed when the menu selection is made.

## Installation & Import

```bash
yarn add @ids-ts/dropdown-button
```

```tsx
import { DropdownButton } from '@ids-ts/dropdown-button';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `automationId` | `string` | No | Automation test id. |
| `buttonPriority` | `Priority` | No | - |
| `buttonPurpose` | `ButtonPurpose` | No | - |
| `buttonSize` | `ButtonSize` | No | - |
| `children` | `ReactElement<MenuItemProps> \| ReactElement<MenuItemProps>[]` | No | MenuItem children for the dropdown. |
| `className` | `string` | No | ClassName to be used on the base element |
| `maxHeight` | `string | number` | No | Determine the maximum height of the dropdown list, unit is px. |
| `disabled` | `boolean` | No | - |
| `icon` | `React.ReactElement` | No | Icon component. Show as ChevronDownIcon if not set. |
| `label` | `string` | No | Label to be used for the button tertiary |
| `menuClassName` | `string` | No | Custom classname to pass to the underlying Menu component. |
| `onOpen` | `() => void` | No | Called when the menu button is clicked and the menu is opened. |
| `onSelect` | `(e: React.MouseEvent | React.KeyboardEvent) => ...` | No | Called when menu items are selected. |
| `preventMenuOverflow` | `an object variable` | Yes | - |
| `preventMenuOverflow` | `PreventOverflow` | No | - |
| `style` | `React.CSSProperties` | No | styles to be used on the base element |
| `stylePosition` | `React.CSSProperties` | No | The optional styles applied to the position node wrapped around the root node. |
| `positions` | `string[]` | No | Vertical positions: `'top'`, `'bottom'`. |
| `alignments` | `string[]` | No | Alignment of the menu relative to the trigger. |
| `offsetSkidding` | `number` | No | Cross-axis pixel offset of the popup. |
| `offsetDistance` | `number` | No | Main-axis pixel offset of the popup. |
| `scrollToSelected` | `boolean` | No | - |
| `positionDependencies` | `unknown[]` | No | - |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface DropdownButtonProps
  extends Omit<ThemeableElement<'div'>, 'onSelect'> {
  /** Aria label */
  'aria-label'?: string;
  /** Automation  test id. */
  automationId?: string;
  /**
   * Button priority - 'primary', 'secondary' or ''tertiary
   *
   * @default 'primary'
   */
  buttonPriority?: Priority;
  /**
   * Type of dropdown button specified by the user
   * ButtonPurpose - 'standard' or 'passive' or 'complementary' or 'ai'
   *
   * @default 'standard'
   */
  buttonPurpose?: ButtonPurpose;
  /**
   * Size of button and menu - 'small', 'medium' or 'large'
   *
   * @default 'medium'
   */
  buttonSize?: ButtonSize;
  /** Children of Menu, which are MenuItem types in the dropdown */
  children?:
    | React.ReactElement<MenuItemProps>
    | React.ReactElement<MenuItemProps>[];
  /** ClassName to be used on the base element */
  className?: string;
  /** Determine the maximum height of the dropdown list, unit is px. */
  maxHeight?: string | number;
  /**
   * Whether dropdown button should be disabled
   *
   * @default false
   */
  disabled?: boolean;
  /** Icon component. Show as ChevronDownIcon if not set. */
  icon?: React.ReactElement;
  /** Label to be used for the button tertiary */
  label?: string;
  /** Custom classname to pass to the underlying Menu component. */
  menuClassName?: string;
  /** Called when the menu button is clicked and the menu is opened. */
  onOpen?: () => void;
  /** Called when menu items are selected. */
  onSelect?: (e: React.MouseEvent | React.KeyboardEvent) => void;
  /**
   * preventMenuOverflow: an object variable; used to prevent DropdownButton Menu from being positioned outside the boundary.
   * More detail in @ids-ts/position preventOverflow API document.
   */
  preventMenuOverflow?: PreventOverflow;
  /** styles to be used on the base element */
  style?: React.CSSProperties;
  /** The optional styles applied to the position node wrapped around the root node. */
  stylePosition?: React.CSSProperties;
  /**
   * vertical positions: top, bottom
   * horizontal positions: left, right
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   *
   * @default 'bottom'
   */
  position?: Positions;
  /**
   * vertical alignments: top, bottom, middle
   * horizontal alignments: left, right, center
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   *
   * @default 'right'
   */
  alignment?: Alignments;
  /**
   * offsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  offsetSkidding?: number;
  /**
   * offsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  offsetDistance?: number;
  /**
   * Scroll current selected item into view from Menu if necessary
   *
   * @default false
   */
  scrollToSelected?: boolean;
  /**
   * Dependencies that will cause the Menu's popperjs instance to recalculate its position, whenever any of the dependencies change.
   * These dependencies work the same way as the list you would pass into a React useEffect()
   */
  positionDependencies?: unknown[];
}

export type ButtonPurpose = Filter<
  Purpose,
  'standard' | 'passive' | 'complementary' | 'ai'
>;

export type Positions = 'top' | 'bottom' | 'left' | 'right';

export type Alignments =
  | 'left'
  | 'right'
  | 'top'
  | 'bottom'
  | 'middle'
  | 'center';
```

</details>

