### Accessibility Example

```tsx
() => {
  const [open, setOpen] = React.useState(true);
  const buttonRef = React.createRef<HTMLButtonElement>();

  React.useEffect(() => {
    if (open === false) {
      buttonRef.current && buttonRef.current.focus && buttonRef.current.focus();
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [open]);

  const handleClose = () => {
    setOpen(false);
  };

  return (
    <div>
      <B2>
        Focus should move to the next focus-able element once a page message is
        closed.
      </B2>
      <PageMessage
        title="Title"
        automationId="accessibility"
        open={open}
        className={`${styles.pageMessage}`}
        onClose={handleClose}
      >
        <B3>{faker.lorem.sentence(20)}</B3>
      </PageMessage>
      <Button innerRef={buttonRef}>Focus will move to me</Button>
    </div>
  );
}
```

