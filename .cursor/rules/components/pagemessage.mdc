## Usage Patterns

### Basic Usage

```tsx
() => {
  const [open, setOpen] = useState(true);

  const handleClose = () => setOpen(false);

  return (
    <PageMessage
      title="Title"
      automationId="basic"
      open={open}
      onClose={handleClose}
    >
      <B3>{faker.lorem.lines(4)}</B3>
    </PageMessage>
  );
}
```

### Types

```tsx
() => {
  const [openStates, setOpenStates] = useState<any>(types);

  const handleClose = (type: string) => {
    const newOpenStates: any = { ...openStates };
    newOpenStates[type] = false;
    setOpenStates(newOpenStates);
  };

  return Object.keys(types).map((type) => (
    <div key={type}>
      {openStates[type] && <p>{capitalizeString(type)}:</p>}
      <PageMessage
        key={type}
        open={openStates[type]}
        title={capitalizeString(type)}
        dismissible={type !== 'error'}
        type={type as PageMessageType}
        onClose={() => handleClose(type)}
      >
        {faker.lorem.sentence(20)}
      </PageMessage>
    </div>
  ));
}
```

