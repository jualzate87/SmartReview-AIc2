## Usage Patterns

### Basic Example

```tsx
() => (
  <CloseIconControl size="medium" onClick={action('Clicked BasicExample')} />
)
```

### No Visible Label Use Aria Label For Accessibility

```tsx
() => {
  return (
    <div>
      <h3>No Visible Label Example</h3>
      <CloseIconControl
        aria-label="remove row"
        size="medium"
        onClick={action('Clicked AriaExample')}
      />
      <p>
        The element is used to associate a text label with a form field. The
        label is used to tell users the value that should be entered in the
        associated input field. If your design does not include a visible label,
        then you must include an aria-label to provide information to the screen
        reader.
      </p>
    </div>
  );
}
```

### Disabled Icon Control

```tsx
() => (
  <EditIconControl
    disabled
    size="medium"
    onClick={action('Clicked DisabledIconControl')}
  />
)
```

### Selected Icon Control

```tsx
() => (
  <EditIconControl
    selected
    size="medium"
    onClick={action('Clicked SelectedIconControl')}
  />
)
```

### Complementary Icon Control

```tsx
() => (
  <EditIconControl
    complementary
    aria-label="Edit my W2 form"
    size="medium"
    onClick={action('Clicked ComplementaryIconControl')}
  />
)
```

### Icon Control With Sizes

```tsx
() => {
  const handleClick = (size: string) =>
    action(`Clicked ${size} IconControlWithSizes`);

  return (
    <div className={styles.iconControlWithSizesDiv}>
      <div className={styles.iconControlWithSizesInnerDiv}>
        <CloseIconControl size="x-small" onClick={handleClick('x-small')} />
      </div>
      <div className={styles.iconControlWithSizesInnerDiv}>
        <CloseIconControl size="small" onClick={handleClick('small')} />
      </div>
      <div className={styles.iconControlWithSizesInnerDiv}>
        <CloseIconControl size="medium" onClick={handleClick('medium')} />
      </div>
      <div className={styles.iconControlWithSizesInnerDiv}>
        <CloseIconControl size="large" onClick={handleClick('large')} />
      </div>
    </div>
  );
}
```

### Icon Control With Shapes

```tsx
() => {
  const handleClick = (shape: string) => action(`Clicked ${shape} IconControl`);

  return (
    <div className={styles.iconControlWithSizesDiv}>
      <div className={styles.iconControlWithSizesInnerDiv}>
        <CloseIconControl onClick={handleClick('square')} />
      </div>
      <div className={styles.iconControlWithSizesInnerDiv}>
        <CloseIconControl shape="circle" onClick={handleClick('circle')} />
      </div>
    </div>
  );
}
```

### Assign Icon Control Ref Prop

```tsx
() => {
  const closeButtonRef = React.createRef<HTMLButtonElement>();

  return (
    <CloseIconControl
      ref={closeButtonRef}
      size="medium"
      onClick={action('Clicked AssignIconControlRefProp')}
    />
  );
}
```

