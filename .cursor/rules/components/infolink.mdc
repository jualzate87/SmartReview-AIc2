# InfoLink

InfoLink allow users to click on a "link" to see more information in a tooltip-like format.

## Installation & Import

```bash
yarn add @ids-ts/info-link
```

```tsx
import { InfoLink } from '@ids-ts/info-link';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `a11yFocus` | `boolean` | No | adds some a11y styling |
| `automationId` | `string` | No | Automation ID property to be used for functional tests. |
| `enableClickAway` | `boolean` | No | Dismisses tooltip on clicking away, defaults to true * |
| `message` | `string | React.ReactElement` | Yes | message: inner content of the tooltip |
| `onBlur` | `React.FocusEventHandler` | No | callback for when info-link is blur |
| `onClick` | `React.MouseEventHandler` | No | callback for when info-link is clicked |
| `onKeyDown` | `React.KeyboardEventHandler` | No | callback for when info-link is clicked by keyboard |
| `onTooltipClose` | `(event: ReactEvents) => void` | No | onTooltipClose: callback for when tooltip is closed |
| `tooltipOffsetX` | `the x axis pixel distance that the Tooltip shou...` | Yes | - |
| `offsetY` | `the y axis pixel distance that the Tooltip shou...` | Yes | - |
| `tooltipOffsetSkidding` | `the cross-axis pixel distance that the popup sh...` | Yes | - |
| `tooltipOffsetDistance` | `the main-axis pixel distance that the popup sho...` | Yes | - |
| `preventTooltipOverflow` | `an object variable` | Yes | - |
| `preventTooltipOverflow` | `PreventOverflow` | No | - |
| `stylePosition` | `React.CSSProperties` | No | The optional styles applied to the position node wrapped around the root node. |
| `size` | `InfoLinkSize` | No | possible size of info link label |
| `title` | `string` | No | title for tooltip |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface InfoLinkProps extends ThemeableElement<'span'> {
  /** adds some a11y styling */
  a11yFocus?: boolean;
  /** Automation ID property to be used for functional tests. */
  automationId?: string;
  /** Dismisses tooltip on clicking away, defaults to true **/
  enableClickAway?: boolean;
  /** message: inner content of the tooltip */
  message: string | React.ReactElement;
  /** callback for when info-link is blur */
  onBlur?: React.FocusEventHandler;
  /** callback for when info-link is clicked */
  onClick?: React.MouseEventHandler;
  /** callback for when info-link is clicked by keyboard */
  onKeyDown?: React.KeyboardEventHandler;
  /** onTooltipClose: callback for when tooltip is closed */
  onTooltipClose?: (event: ReactEvents) => void;
  /** tooltipOffsetX: the x axis pixel distance that the Tooltip should be offset from the InfoLink text.
   *
   * @deprecated Please use tooltipOffsetSkidding instead
   */
  tooltipOffsetX?: number;
  /** offsetY: the y axis pixel distance that the Tooltip should be offset from the InfoLink text.
   *
   * @deprecated Please use tooltipOffsetDistance instead
   */
  tooltipOffsetY?: number;
  /**
   * tooltipOffsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  tooltipOffsetSkidding: number;
  /**
   * tooltipOffsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  tooltipOffsetDistance: number;
  /**
   * preventTooltipOverflow: an object variable; used to prevent InfoLink Tooltip from being positioned outside the boundary.
   *  More detail in @ids-ts/position preventOverflow API document.
   */
  preventTooltipOverflow?: PreventOverflow;
  /** The optional styles applied to the position node wrapped around the root node. */
  stylePosition?: React.CSSProperties;
  /** possible size of info link label */
  size?: InfoLinkSize;
  /** title for tooltip */
  title?: string;
}

export type ReactEvents =
  | React.MouseEvent
  | React.KeyboardEvent
  | React.FocusEvent
  | React.TouchEvent;

export type InfoLinkSize = 'small' | 'medium' | 'inherit';
```

</details>

