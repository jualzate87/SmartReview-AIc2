### With Addon Before Label

```tsx
() => {
  const [value, setValue] = useState('0');
  const onChange = (e: any) => setValue(e.target.value);

  const getAddonBeforeContent = () => {
    if (Number(value) > 0) {
      return (
        <Badge status="success" style={{ margin: '8px' }}>
          {value}
        </Badge>
      );
    }

    return undefined;
  };

  return (
    <Dropdown
      label="Fruit"
      addonBeforeContent={getAddonBeforeContent()}
      data-automation-id="addonBeforeLabel"
      aria-label="Choose a fruit"
      value={value}
      onChange={onChange}
    >
      <MenuItem value="1">Banana</MenuItem>
      <MenuItem value="2">Apple</MenuItem>
      <MenuItem value="3">Guava</MenuItem>
      <MenuItem value="4">Durian</MenuItem>
    </Dropdown>
  );
}
```

### Rich Menu Items

```tsx
() => {
  const [value1, setValue1] = useState('');
  const [value2, setValue2] = useState('');

  const credentials = [
