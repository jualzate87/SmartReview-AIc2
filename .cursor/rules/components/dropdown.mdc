### Controlled

```tsx
() => {
  const [value, setValue] = useState<string | undefined>(undefined);
  const [multiselectValues, setMultiselectValues] = useState<string[]>([]);

  const handleSingleChange = (e: KeyboardEvent | MouseEvent) => {
    const target = e.target as HTMLSelectElement;
    action('Controlled onChange: ')(target.value);
    setValue(target.value);
  };

  const handleMultiselectChange = (e: KeyboardEvent | MouseEvent) => {
    const target = e.target as HTMLSelectElement;
    // In controlled mode, the component provides the complete updated array
    const newValue = Array.isArray(target.value)
      ? target.value
      : [target.value];
    action('Controlled multiselect onChange: ')(newValue);
    setMultiselectValues(newValue as string[]);
  };

  const handleReset = () => {
    setValue(undefined);
    setMultiselectValues([]);
  };

  return (
    <div>
      <div style={{ marginBottom: '20px' }}>
        <Dropdown
          controlled
          width="305px"
          label="Controlled Single Select Dropdown"
          placeholder="Select a continent"
          value={value}
          className={styles.exampleDropdown}
          aria-label="controlled-single-select"
          id="controlled-single-select"
          onChange={handleSingleChange}
        >
          <MenuItem value="1">Africa</MenuItem>
          <MenuItem value="2">Antartica</MenuItem>
          <MenuItem value="3">Asia</MenuItem>
          <MenuItem value="4">Europe</MenuItem>
          <MenuItem value="5">Oceania</MenuItem>
          <MenuItem value="6">North America</MenuItem>
          <MenuItem value="7">South America</MenuItem>
        </Dropdown>
        <div style={{ marginTop: '10px', fontSize: '14px', color: '#666' }}>
          Selected Value: {value || 'None'}
        </div>
      </div>

      <div style={{ marginBottom: '20px' }}>
        <Dropdown
          controlled
          multiselect
          width="305px"
          label="Controlled Multi-Select Dropdown"
          placeholder="Select continents"
          value={multiselectValues}
          className={styles.exampleDropdown}
          aria-label="controlled-multi-select"
          id="controlled-multi-select"
          onChange={handleMultiselectChange}
        >
          <MenuItem value="1">Africa</MenuItem>
          <MenuItem value="2">Antartica</MenuItem>
          <MenuItem value="3">Asia</MenuItem>
          <MenuItem value="4">Europe</MenuItem>
          <MenuItem value="5">Oceania</MenuItem>
          <MenuItem value="6">North America</MenuItem>
          <MenuItem value="7">South America</MenuItem>
        </Dropdown>
