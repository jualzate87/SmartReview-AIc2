      name: 'Development AWS',
      account: 'AWS Account: 234567890123',
      code: '8432'
    },
    {
      value: 'cred-3',
      name: 'Staging Environment',
      account: 'AWS Account: 345678901234',
      code: '5109'
    }
  ];

  return (
    <div>
      <p style={{ marginBottom: '16px' }}>
        This example demonstrates how to render rich, multi-line dropdown items
        with custom styling. When using React elements as children, provide
        either <code>menuItemLabel</code> (recommended) or <code>value</code> to
        control what appears in the closed dropdown field.
      </p>

      <h4 style={{ marginBottom: '8px' }}>With menuItemLabel (Recommended)</h4>
      <p style={{ marginBottom: '8px', fontSize: '14px', color: '#666' }}>
        Use <code>menuItemLabel</code> to specify a custom display string:
      </p>
      <Dropdown
        label="Select Credential"
        placeholder="Choose a credential..."
        data-automation-id="rich-items-with-label"
        aria-label="Select a credential with label"
        className={styles.exampleDropdown}
        value={value1}
        onChange={(e: any) => setValue1(e.target.value)}
      >
        {credentials.map((cred) => (
          <MenuItem
            key={cred.value}
            value={cred.value}
            menuItemLabel={cred.name}
          >
            <div className={styles.richItemContainer}>
              <span className={styles.richItemPrimary}>{cred.name}</span>
              <span className={styles.richItemSecondary}>
                {cred.account}
                <Badge status="info" className={styles.richItemBadge}>
                  {cred.code}
                </Badge>
              </span>
            </div>
          </MenuItem>
        ))}
      </Dropdown>
      <p style={{ marginTop: '8px', marginBottom: '24px', fontSize: '14px' }}>
        Selected shows:{' '}
        <strong>
          {value1 ? credentials.find((c) => c.value === value1)?.name : 'None'}
        </strong>
      </p>

      <h4 style={{ marginBottom: '8px' }}>
        Without menuItemLabel (Falls back to value)
      </h4>
      <p style={{ marginBottom: '8px', fontSize: '14px', color: '#666' }}>
