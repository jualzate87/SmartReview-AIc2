### Render From Props

```tsx
() => {
  const [value, setValue] = useState('0');
  const onChange = (e: any) => {
    if (e.target.name === 'Fruit') {
      setValue(e.target.value);
    }
  };

  return (
    <div>
      <span>
        Dropdown`s With Declined Selection Change and render from props
      </span>
      <Dropdown
        name="Name"
        label="Name without renderFromProps"
        value={value}
        className={styles.exampleDropdown}
        onChange={onChange}
      >
        <MenuItem value="1">Banana</MenuItem>
        <MenuItem value="2">Apple</MenuItem>
        <MenuItem value="3">Guava</MenuItem>
        <MenuItem value="4">Mango</MenuItem>
      </Dropdown>
      <Dropdown
        renderFromProps
        name="Fruit"
        label="Fruit with renderFromProps"
        value={value}
        onChange={onChange}
      >
        <MenuItem value="1">Banana</MenuItem>
        <MenuItem value="2">Apple</MenuItem>
        <MenuItem value="3">Guava</MenuItem>
        <MenuItem value="4">Mango</MenuItem>
      </Dropdown>
    </div>
  );
}
```

### Update Position

```tsx
() => {
  const [y, setY] = useState(0);

  useEffect(() => {
    const timerId = setInterval(() => {
      setY((oldY) => (oldY + 100) % 600);
    }, 1500);

    return () => {
      clearInterval(timerId);
    };
  }, []);

  return (
    <div
      style={{
        marginTop: y
      }}
    >
      <Dropdown
        label="Fruit"
        data-automation-id="basic"
        aria-label="Choose a fruit"
        positionDependencies={[y]}
        onChange={action('onChange')}
      >
        <MenuItem value="1">Banana</MenuItem>
        <MenuItem value="2">Apple</MenuItem>
        <MenuItem value="3">Guava</MenuItem>
        <MenuItem value="4">Durian</MenuItem>
      </Dropdown>
    </div>
  );
}
```

