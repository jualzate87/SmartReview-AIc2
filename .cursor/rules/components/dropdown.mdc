# Dropdown

Dropdowns are used to select a value from a series of options in a list.
Dropdowns support mouse and key input.
If you are not using a string or number for the child of MenuItem, use the displayedLabel prop on Dropdown to provide the name of a prop on MenuItem with a string to be displayed when selected.

## Installation & Import

```bash
yarn add @ids-ts/dropdown
```

```tsx
import { Dropdown } from '@ids-ts/dropdown';
```

## Props API

| Prop | Type | Required | Description |
| --- | --- | --- | --- |
| `automationId` | `string` | No | ID for automation test. |
| `addonBeforeContent` | `ReactElement` | No | Prop to set desired Icon/ addonBefore element |
| `children` | `ReactElement<MenuItemProps> | ReactElement<Menu...` | No | Children of Menu, which are MenuItem types in the dropdown |
| `disabled` | `boolean` | No | Disable dropdown if true. |
| `enableFilterItems` | `boolean` | No | - |
| `filterFieldWidth` | `string` | No | * Control filter textfield width |
| `enableOnBlurOnMultiselect` | `boolean` | No | - |
| `errorText` | `string` | No | Error message to be rendered. |
| `hasWeightedLabel` | `boolean` | No | Boolean flag to allow label to be bold |
| `infoText` | `string` | No | Info message to be rendered. |
| `filterPlaceholder` | `string` | No | - |
| `helperText` | `string` | No | helper message to be rendered. |
| `id` | `string` | No | Id for component. |
| `label` | `string` | No | Label to be displayed for the field. |
| `menuClass` | `string` | No | Class to be applied to menu. |
| `multiselect` | `boolean` | No | Enable Multi Select dropdown if true. |
| `name` | `string` | No | Name to be assigned to the input field. |
| `onBlur` | `(e: FocusEvent, infoObject?: OnEventInfoType) =...` | No | Callback function to be executed on blur event. |
| `onChange` | `(e: KeyboardEvent \| MouseEvent, infoObject?: object) => void` | No | Callback on change, receives event and value info. |
| `onClose` | `(type: 'clickAway' \| 'select') => void` | No | Called when the dropdown closes, with close reason. |
| `onOpen` | `() => void` | No | Callback function to be executed on dropdown open event. |
| `onClick` | `(e: MouseEvent) => void` | No | - |
| `preventMenuOverflow` | `an object variable` | Yes | - |
| `preventMenuOverflow` | `PreventOverflow` | No | - |
| `readOnly` | `boolean` | No | - |
| `renderFromProps` | `boolean` | No | Display value directly from props, do not memoize it |
| `searchMode` | `searchType` | No | - |
| `validationError` | `boolean` | No | change text field color to warn user without text and icon |
| `value` | `string | number | (string | number)[]` | No | Selected value. |
| `warningText` | `string` | No | warning message to be rendered. |
| `stylePosition` | `CSSProperties` | No | The optional styles applied to the position node wrapped around the root node. |
| `positions` | `string[]` | No | Vertical positions: `'top'`, `'bottom'`. |
| `alignments` | `string[]` | No | Alignment of the dropdown menu relative to the trigger. |
| `offsetSkidding` | `number` | No | Cross-axis pixel offset of the popup. |
| `offsetDistance` | `number` | No | Main-axis pixel offset of the popup. |
| `width` | `string \| number` | No | Width of the dropdown. Defaults to `'fit-content'`. |
| `size` | `'small' \| 'medium'` | No | Font size variant: `'small'` (14px) or `'medium'` (16px). |
| `positionDependencies` | `unknown[]` | No | - |
| `controlled` | `boolean` | No | When true, component won't manage its own open state. |
| `selectedItem` | `ReactEventRelatedTarget | ReactFocusEventRelate...` | No | A selected item |
| `target` | `{ e?: ReactEventRelatedTarget }` | No | Index of highlighted item in Menu. |
| `name` | `string` | No | name |

<details>
<summary>Full TypeScript Interface</summary>

```typescript
export interface DropdownProps
  extends Omit<
    ThemeableElement<'input'>,
    'onChange' | 'onBlur' | 'size' | 'value'
  > {
  /** ID for automation test. */
  automationId?: string;
  /** Prop to set desired Icon/ addonBefore element */
  addonBeforeContent?: ReactElement;
  /** Children of Menu, which are MenuItem types in the dropdown */
  children?: ReactElement<MenuItemProps> | ReactElement<MenuItemProps>[];
  /**  Disable dropdown if true. */
  disabled?: boolean;
  /**
   * Filter option for dropdown menu items
   *
   * @default false
   */
  enableFilterItems?: boolean;
  /**
   * Control filter textfield width
   */
  filterFieldWidth?: string;
  /**
   * Flag to set if onBlur should be called on multiSelect.
   * Added to ensure we do not break existing users.
   *
   * @default false
   */
  enableOnBlurOnMultiselect?: boolean;
  /**  Error message to be rendered. */
  errorText?: string;
  /** Boolean flag to allow label to be bold */
  hasWeightedLabel?: boolean;
  /**  Info message to be rendered. */
  infoText?: string;
  /**  Placeholder string for the search filter.
   *
   * @default 'Filter'
   */
  filterPlaceholder?: string;
  /** helper message to be rendered. */
  helperText?: string;
  /**  Id for component. */
  id?: string;
  /** Label to be displayed for the field. */
  label?: string;
  /** Class to be applied to menu. */
  menuClass?: string;
  /** Enable Multi Select dropdown if true. */
  multiselect?: boolean;
  /** Name to be assigned to the input field. */
  name?: string;
  /** Callback function to be executed on blur event. */
  onBlur?: (e: FocusEvent, infoObject?: OnEventInfoType) => void;
  /** Callback function to be executed on change, receives 2 params: event object and value. */
  onChange?: (
    e: KeyboardEvent | MouseEvent,
    infoObject?: OnEventInfoType
  ) => void;
  /**
   * Callback function to handle filter, also performs callback with value { type: 'clickAway' }
   * when clicked away from the filter input field
   */
  onItemsFilter?: (arg?: Record<'type', string>) => void;
  /** Callback function to be executed on dropdown open event. */
  onOpen?: () => void;
  /**
   * Callback function to be executed upon receiving a click event on menu
   * anchor element.
   */
  onClick?: (e: MouseEvent) => void;
  /**
   * preventMenuOverflow: an object variable; used to prevent Dropdown Menu from being positioned outside the boundary.
   * More detail in @ids-ts/position preventOverflow API document.
   */
  preventMenuOverflow?: PreventOverflow;
  /**
   * Readonly prop to pass on to root when set as true.
   *
   * @default false
   */
  readOnly?: boolean;
  /** Display value directly from props, do not memoize it */
  renderFromProps?: boolean;
  /**
   * Determine which search type to apply while typing
   * full - search sequentially adding typed symbol from the beginning
   * first - mimic all behavior to match first char only
   * partial - search for the first occurrence in the middle of displayed items
   *
   * @default 'full'
   */
  searchMode?: searchType;
  /** change text field color to warn user without text and icon */
  validationError?: boolean;
  /** Selected value. */
  value?: string | number | (string | number)[];
  /** warning message to be rendered. */
  warningText?: string;
  /** The optional styles applied to the position node wrapped around the root node. */
  stylePosition?: CSSProperties;
  /**
   * vertical positions: top, bottom
   * horizontal positions: left, right
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   *
   * @default 'bottom'
   */
  position?: Positions;
  /**
   * vertical alignments: top, bottom, middle
   * horizontal alignments: left, right, center
   * NOTE: horizontal alignments cannot be paired with horizontal positions
   *
   * @default 'right'
   */
  alignment?: Alignments;
  /**
   * offsetSkidding: the cross-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  offsetSkidding?: number;
  /**
   * offsetDistance: the main-axis pixel distance that the popup should be offset from targetElement
   *
   * @default 0
   */
  offsetDistance?: number;
  /**
   * width: width of the dropdown
   *
   * @default 'fit-content'
   */
  width?: string | number;
  /**
   * size: choose whether to render with small (14px) or medium (16px) font-size for children
   *
   * @default 'medium'
   */
  size?: 'small' | 'medium';
  /**
   * Dependencies that will cause the Menu's popperjs instance to recalculate its position, whenever any of the dependencies change.
   * These dependencies work the same way as the list you would pass into a React useEffect()
   */
  positionDependencies?: unknown[];
  /**
   * controlled: when true, the component will not manage its own selection state.
   * The parent must update the value prop in the onChange callback.
   * Note: onChange is required when controlled is true.
   *
   * @default false
   */
  controlled?: boolean;
}

export type OnEventInfoType = {
  /** A selected item */
  selectedItem?: ReactEventRelatedTarget | ReactFocusEventRelatedTarget;
  /** Index of highlighted item in Menu */
  target?: {
    /** ReactEventRelatedTarget */
    e?: ReactEventRelatedTarget;
    /** name */
    name?: string;
  };
}

export type ReactEventRelatedTarget = ReactDropdownEvent & {

export type ReactFocusEventRelatedTarget = React.FocusEvent & {

export type Positions = 'top' | 'bottom' | 'left' | 'right';

export type Alignments =
  | 'left'
  | 'right'
  | 'top'
  | 'bottom'
  | 'middle'
  | 'center';
```

</details>

