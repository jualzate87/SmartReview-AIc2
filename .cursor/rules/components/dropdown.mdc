## Usage Patterns

### Playground

```tsx
({
  alignment,
  changeDisplayWhenSelected,
  disabled,
  disableFirstMenuItem,
  disableSecondMenuItem,
  errorText,
  helperText,
  infoText,
  label,
  multiselect,
  offsetDistance,
  offsetSkidding,
  placeholder,
  position,
  searchMode,
  warningText
}) => {
  const [value, setValue] = useState<string | undefined>(undefined);
  const [values, setValues] = useState(['']);

  const onChange = (e: KeyboardEvent | MouseEvent) => {
    const target = e.target as HTMLSelectElement;

    if (!multiselect) {
      action('onChange: ')(target.value);
      setValue(target.value);
    } else if (values.includes(target.value)) {
      values.splice(values.indexOf(target.value), 1);
      setValues(values);
    } else {
      values.push(target.value);
      setValues(values);
    }
  };

  return (
    <Dropdown
      width="305px"
      disabled={disabled}
      multiselect={multiselect}
      validationError={errorText !== '' || warningText !== ''}
      label={label}
      placeholder={placeholder}
      helperText={helperText}
      errorText={errorText}
      warningText={warningText}
      infoText={infoText}
      searchMode={searchMode}
      value={multiselect ? values : value}
      data-automation-id="basic"
      position={position}
      alignment={alignment}
      offsetSkidding={offsetSkidding}
      offsetDistance={offsetDistance}
      onChange={onChange}
    >
      <MenuItem
        disabled={disableFirstMenuItem}
        menuItemLabel={
          changeDisplayWhenSelected ? 'Africa selected' : undefined
        }
        value="1"
      >
        Africa
      </MenuItem>
      <MenuItem
        disabled={disableSecondMenuItem}
        menuItemLabel={
          changeDisplayWhenSelected ? 'Antartica selected' : undefined
        }
        value="2"
      >
        Antartica
      </MenuItem>
      <MenuItem
        menuItemLabel={changeDisplayWhenSelected ? 'Asia selected' : undefined}
        value="3"
      >
        Asia
// ...
```

