## Usage Patterns

### Playground

```tsx
({
  checkRounded,
  checkStrokeWidth,
  endWithCheckmark,
  endWithFill,
  size,
  spinnerType
}) => {
  const [progress, setProgress] = useState(0);

  useEffect(() => {
    if (progress === 0) {
      increase(progress, 8, setProgress);
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  const handleClick = () => {
    if (progress >= 100) {
      increase(-8, 8, setProgress);
    } else {
      action('Button Clicked. Spinner still in progress, please wait.')();
    }
  };

  return spinnerType === 'DeterminateLong' ? (
    <>
      <DeterminateLong
        progress={progress}
        aria-label="A basic DeterminateLong"
        endWithFill={endWithFill}
        endWithCheckmark={endWithCheckmark}
        checkRounded={checkRounded}
        checkStrokeWidth={checkStrokeWidth}
        tabIndex={0}
        data-testid="longIntuitBasic"
      />
      <Button onClick={handleClick}>Restart</Button>
    </>
  ) : (
    <DeterminateShort
      progress={progress}
      size={size}
      aria-label="A basic DeterminateLong"
      endWithFill={endWithFill}
      endWithCheckmark={endWithCheckmark}
      checkRounded={checkRounded}
      checkStrokeWidth={checkStrokeWidth}
      tabIndex={0}
      data-testid="shortIntuitBasic"
    />
  );
}
```

### Showcase

```tsx
() => {
  const [progress, setProgress] = useState(0);

  useEffect(() => {
    if (progress === 0) {
      increase(progress, 8, setProgress);
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  const handleClick = () => {
    if (progress >= 100) {
      increase(-8, 8, setProgress);
    } else {
      action('Button Clicked. Spinner still in progress, please wait.')();
    }
  };

  return (
    <>
      <div>
        <h3>Determinate Long Spinner</h3>
        <DeterminateLong
          progress={progress}
          aria-label="A basic DeterminateLong"
          checkStrokeWidth={20}
          tabIndex={0}
          data-testid="longIntuitBasic"
        />
      </div>
      <div>
        <h3>Determinate Short Spinner</h3>
        <DeterminateShort
          progress={progress}
          size={64}
          aria-label="A basic DeterminateLong"
          checkStrokeWidth={20}
          tabIndex={0}
          data-testid="shortIntuitBasic"
        />
      </div>
      <Button onClick={handleClick}>Restart</Button>
    </>
  );
}
```

