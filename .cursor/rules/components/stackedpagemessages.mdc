## Usage Patterns

### Basic Usage

```tsx
() => {
  const [open, setOpen] = useState(true);
  const [isInfoOpen, setIsInfoOpen] = useState(true);
  const [isWarningOpen, setIsWarningOpen] = useState(true);
  const [isErrorOpen, setIsErrorOpen] = useState(true);
  const [isDiscoveryOpen, setIsDiscoveryOpen] = useState(true);

  const handleClose = () => setOpen(false);

  return (
    <div id="basicExample">
      <StackedPageMessages
        automationId="basic"
        open={open}
        style={{ overflow: 'auto' }}
        onClose={handleClose}
      >
        <PageMessage
          title="Info"
          type="info"
          open={isInfoOpen}
          onClose={() => setIsInfoOpen(false)}
        >
          {loremIpsum}
        </PageMessage>
        <PageMessage
          title="Warning"
          type="warn"
          open={isWarningOpen}
          onClose={() => setIsWarningOpen(false)}
        >
          {loremIpsum}
        </PageMessage>
        <PageMessage
          title="Error"
          type="error"
          open={isErrorOpen}
          dismissible={false}
          onClose={() => setIsErrorOpen(false)}
        >
          {loremIpsum}
        </PageMessage>
        <PageMessage
          title="Discovery"
          type="discovery"
          open={isDiscoveryOpen}
          onClose={() => setIsDiscoveryOpen(false)}
        >
          {loremIpsum}
        </PageMessage>
      </StackedPageMessages>
    </div>
  );
}
```

